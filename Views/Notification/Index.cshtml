@model IEnumerable<GestionProjects.Domain.Models.Notification>

@{
    ViewData["Title"] = "Mes Notifications";
    var nonLues = ViewBag.NonLues as int? ?? 0;
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="notification-shell fade-in">
    <section class="phase-hero">
        <div class="phase-hero-top">
            <div>
                <div class="phase-eyebrow">
                    <i class="bi bi-bell"></i>
                    Notifications
                </div>
                <h2 class="phase-title">Centre de notifications</h2>
                <p class="phase-subtitle">
                    Suivez les demandes de validation, alertes projet et evenements importants sans perdre le fil de vos priorites.
                </p>
            </div>
            <div class="phase-action-row">
                <span class="phase-chip @(nonLues > 0 ? "is-danger" : "is-success")">
                    <i class="bi @(nonLues > 0 ? "bi-bell-fill" : "bi-check-circle")"></i>
                    @(nonLues > 0 ? $"{nonLues} non lue(s)" : "Tout est lu")
                </span>
                @if (nonLues > 0)
                {
                    <form asp-action="MarquerToutesLues" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                        <button type="submit" class="btn-modern btn-modern-secondary">
                            <i class="bi bi-check-all"></i>
                            Tout marquer comme lu
                        </button>
                    </form>
                }
            </div>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="phase-empty">
            <i class="bi bi-bell-slash"></i>
            <p>Aucune notification pour le moment.</p>
        </div>
    }
    else
    {
        <div class="notification-list">
            @foreach (var notification in Model)
            {
                <article class="notification-card @(!notification.EstLue ? "is-unread" : string.Empty)">
                    <div class="notification-card-header">
                        <div style="flex: 1;">
                            <div class="notification-card-title">
                                @Html.Raw(GetNotificationIcon(notification.TypeNotification))
                                <span>@notification.Titre</span>
                                @if (!notification.EstLue)
                                {
                                    <span class="badge-modern badge-modern-primary">Nouveau</span>
                                }
                            </div>
                            <div class="notification-card-body">
                                @notification.Message
                            </div>
                            <div class="notification-card-footer" style="margin-top: .9rem;">
                                <span>
                                    <i class="bi bi-clock"></i>
                                    @notification.DateCreation.ToString("dd/MM/yyyy à HH:mm")
                                </span>
                                @if (notification.EntiteType != null && notification.EntiteId.HasValue)
                                {
                                    <a href="@GetEntityUrl(notification.EntiteType, notification.EntiteId.Value)" class="phase-link">
                                        <i class="bi bi-arrow-right-circle"></i>
                                        Ouvrir l'element
                                    </a>
                                }
                            </div>
                        </div>

                        @if (!notification.EstLue)
                        {
                            <form asp-action="MarquerLue" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@notification.Id" />
                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                <button type="submit" class="btn-modern btn-modern-secondary" title="Marquer comme lu">
                                    <i class="bi bi-check"></i>
                                </button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>

        @await Html.PartialAsync("_Pagination")
    }
</div>

@functions {
    string GetNotificationIcon(GestionProjects.Domain.Enums.TypeNotification type)
    {
        return type switch
        {
            GestionProjects.Domain.Enums.TypeNotification.ProjetEntreEnUAT => "<i class='bi bi-check2-square' style='color: var(--info);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.ProjetEntreEnMEP => "<i class='bi bi-rocket' style='color: var(--success);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.DemandeSupportTechnique => "<i class='bi bi-tools' style='color: var(--warning);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.DemandeValidationDSI => "<i class='bi bi-shield-check' style='color: var(--primary-blue);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.DemandeValidationDM => "<i class='bi bi-check-circle' style='color: var(--info);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.ProjetPhaseChangee => "<i class='bi bi-arrow-repeat' style='color: var(--primary-blue);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.NouveauRisqueCritique => "<i class='bi bi-exclamation-triangle' style='color: var(--danger);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.NouvelleAnomalie => "<i class='bi bi-bug' style='color: var(--warning);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.LivrableDepose => "<i class='bi bi-file-earmark' style='color: var(--info);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.DelegationDSIActivee => "<i class='bi bi-person-badge' style='color: var(--success);'></i>",
            GestionProjects.Domain.Enums.TypeNotification.DelegationDSIExpiree => "<i class='bi bi-person-x' style='color: var(--gray-500);'></i>",
            _ => "<i class='bi bi-bell' style='color: var(--gray-500);'></i>"
        };
    }

    string GetEntityUrl(string? entiteType, Guid entiteId)
    {
        return entiteType switch
        {
            "Projet" => Url.Action("Details", "Projet", new { id = entiteId }) ?? "#",
            "DemandeProjet" => Url.Action("Details", "DemandeProjet", new { id = entiteId }) ?? "#",
            "DemandeClotureProjet" => Url.Action("Details", "Projet", new { id = entiteId }) ?? "#",
            _ => "#"
        };
    }
}
