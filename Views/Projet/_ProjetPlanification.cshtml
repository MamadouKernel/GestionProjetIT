                                @if (raciLines.Any())
                                {
                                    <div class="planning-native-table-wrap">
                                        <table class="planning-native-table">
                                            <thead>
                                                <tr>
                                                    <th>Code</th>
                                                    <th>Activité</th>
                                                    <th>R</th>
                                                    <th>A</th>
                                                    <th>C</th>
                                                    <th>I</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in raciLines)
                                                {
                                                    <tr>
                                                        <td>@line.CodeActivite</td>
                                                        <td>@line.Activite</td>
                                                        <td>@line.Responsable</td>
                                                        <td>@line.Approbateur</td>
                                                        <td>@line.Consulte</td>
                                                        <td>@line.Informe</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
