                            <div class="card-header-modern"><h4 class="card-title-modern"><i class="bi bi-kanban"></i> Planning & jalons</h4></div>
                            <div class="card-body-modern">
                                <p><strong>Prochain jalon :</strong> @(string.IsNullOrWhiteSpace(fiche.ProchainJalon) ? "Non renseigné" : fiche.ProchainJalon)</p>
                                <p><strong>Jalons principaux :</strong><br />@(string.IsNullOrWhiteSpace(fiche.JalonsPrincipaux) ? "Non renseignés" : fiche.JalonsPrincipaux)</p>
