                    </div>
                    <div class="col-lg-6 mb-4">
                        <div class="card-modern h-100">
                            <div class="card-header-modern"><h4 class="card-title-modern"><i class="bi bi-people"></i> Communication</h4></div>
                            <div class="card-body-modern">
                                @if (communicationLines.Any())
                                {
                                    <div class="planning-native-table-wrap">
                                        <table class="planning-native-table">
                                            <thead>
                                                <tr>
                                                    <th>Instance</th>
                                                    <th>Objectif</th>
                                                    <th>Fréquence</th>
                                                    <th>Canal</th>
                                                    <th>Participants</th>
                                                    <th>Responsable</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var line in communicationLines)
                                                {
                                                    <tr>
                                                        <td>@line.Instance</td>
                                                        <td>@line.Objectif</td>
                                                        <td>@line.Frequence</td>
                                                        <td>@line.Canal</td>
                                                        <td>@line.Participants</td>
                                                        <td>@line.Responsable</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <p><strong>Fréquence :</strong> @(string.IsNullOrWhiteSpace(fiche.FrequenceReunions) ? "Non renseignée" : fiche.FrequenceReunions)</p>
                                    <p><strong>Participants :</strong><br />@(string.IsNullOrWhiteSpace(fiche.ParticipantsReunions) ? "Non renseignés" : fiche.ParticipantsReunions)</p>
                                    <p><strong>Canal :</strong> @(string.IsNullOrWhiteSpace(fiche.CanalCommunication) ? "Non renseigné" : fiche.CanalCommunication)</p>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 mb-4">
                        <div class="card-modern h-100">
                            <div class="card-header-modern"><h4 class="card-title-modern"><i class="bi bi-cash-stack"></i> Budget & kick-off</h4></div>
                            <div class="card-body-modern">
                                <p><strong>Budget prévisionnel :</strong> @((fiche.BudgetPrevisionnel ?? budgetTotal).ToString("N2")) FCFA</p>
                                <p><strong>Commentaire budgétaire :</strong><br />@(string.IsNullOrWhiteSpace(fiche.CommentaireBudgetPlanification) ? "Non renseigné" : fiche.CommentaireBudgetPlanification)</p>
                                <p><strong>COPIL prévu :</strong> @(fiche.CopilPrevu ? "Oui" : "Non")</p>
                                @if (kickOff.DateReunion.HasValue || !string.IsNullOrWhiteSpace(kickOff.Participants) || !string.IsNullOrWhiteSpace(kickOff.Decisions))
                                {
                                    <p><strong>Kick-off :</strong> @(kickOff.DateReunion?.ToString("dd/MM/yyyy") ?? "Date à préciser")</p>
                                    <p><strong>Participants :</strong><br />@(string.IsNullOrWhiteSpace(kickOff.Participants) ? "Non renseignés" : kickOff.Participants)</p>
                                    <p><strong>Décisions :</strong><br />@(string.IsNullOrWhiteSpace(kickOff.Decisions) ? "Non renseignées" : kickOff.Decisions)</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="planning-gantt-preview-card mt-4">
                <div class="planning-gantt-preview-header">
                    <div>
                        <span class="surface-pill surface-pill-sand">Prévisualisation</span>
                        <h4>Vue Gantt consolidée</h4>
                    </div>
                    <div class="planning-gantt-period">@ganttStart.ToString("dd/MM/yyyy") - @ganttEnd.ToString("dd/MM/yyyy")</div>
                </div>

                @if (planningTasks.Any())
                {
                    <div class="planning-gantt-timeline">
                        <div class="planning-gantt-scale">
                            @for (var index = 0; index < Math.Min(ganttTotalDays, 12); index++)
                            {
                                var markerDate = ganttStart.AddDays(Math.Floor(index * (ganttTotalDays / (double)Math.Min(ganttTotalDays, 12))));
                                <span>@markerDate.ToString("dd/MM")</span>
                            }
                        </div>
                        <div class="planning-gantt-rows">
                            @foreach (var task in planningTasks)
                            {
                                <div class="planning-gantt-row">
                                    <div class="planning-gantt-row-meta">
                                        <strong>@task.CodeWbs</strong>
                                        <span>@task.Libelle</span>
                                        @if (!string.IsNullOrWhiteSpace(task.Responsable))
                                        {
                                            <small>@task.Responsable</small>
                                        }
                                    </div>
                                    <div class="planning-gantt-row-track">
                                        <div class="planning-gantt-bar @(task.EstJalon ? "planning-gantt-bar-milestone" : string.Empty)" style="@barStyle(task)">
                                            <span>@task.Avancement%</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-state-modern">
                        <i class="bi bi-bar-chart-steps"></i>
                        <p>Aucune tâche de planning n'a encore été saisie dans le diagramme de Gantt.</p>
                    </div>
                }
            </div>
        </div>

        <div class="card-modern mt-4">
            <div class="card-header-modern">
                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; gap: var(--spacing-sm); flex-wrap: wrap;">
                    <h4 class="card-title-modern"><i class="bi bi-folder2-open"></i> Livrables de planification</h4>
                    @if (canEditPlanification)
                    {
                        <div class="planning-livrable-actions">
                            <form asp-action="GenererLivrablesPlanificationDepuisGantt" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn-modern btn-modern-secondary">
                                    <i class="bi bi-magic"></i>
                                    Régénérer les livrables natifs
                                </button>
                            </form>
                            <button type="button" class="btn-modern btn-modern-primary" data-bs-toggle="modal" data-bs-target="#uploadLivrableModal" data-phase="PlanificationValidation">
                                <i class="bi bi-upload"></i>
                                Ajouter un livrable externe
                            </button>
                        </div>
                    }
                </div>
            </div>
            <div class="card-body-modern">
                @if (livrablesPlanif.Any())
                {
                    <div style="display: flex; flex-direction: column; gap: var(--spacing-sm);">
                        @foreach (var livrable in livrablesPlanif)
                        {
                            <div class="planning-livrable-row">
                                <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                                    <i class="bi bi-file-earmark" style="font-size: 1.5rem; color: var(--primary-blue);"></i>
                                    <div>
                                        <strong>@livrable.NomDocument</strong>
                                        <div class="soft-note">@livrable.TypeLivrable · déposé le @livrable.DateDepot.ToString("dd/MM/yyyy")</div>
                                    </div>
                                </div>
                                <div style="display: flex; gap: var(--spacing-xs);">
                                    <a asp-controller="Document" asp-action="PreviewProjetLivrable" asp-route-projetId="@Model.Id" asp-route-livrableId="@livrable.Id" target="_blank" class="btn-modern btn-modern-primary icon-button" title="Prévisualiser">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-controller="Document" asp-action="StreamProjetLivrable" asp-route-projetId="@Model.Id" asp-route-livrableId="@livrable.Id" asp-route-download="true" class="btn-modern btn-modern-secondary icon-button" title="Télécharger">
                                        <i class="bi bi-download"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state-modern">
                        <i class="bi bi-inbox"></i>
                        <p>Aucun livrable de planification n'a encore été généré ou déposé.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_DossierSignature", Model)

<script nonce="@cspNonce">
    window.planningBoard = window.planningBoard || {
        addTaskRow: function () {
            const tbody = document.querySelector('#planningTasksTable tbody');
            if (!tbody) return;

            const row = document.createElement('tr');
            row.className = 'planning-task-row';
            row.innerHTML = `
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="CodeWbs" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Libelle" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Responsable" /></td>
                <td><input type="date" class="form-control-modern form-control-modern-compact" data-field="DateDebutPrevue" /></td>
                <td><input type="date" class="form-control-modern form-control-modern-compact" data-field="DateFinPrevue" /></td>
                <td><div class="planning-progress-cell"><input type="range" min="0" max="100" step="5" class="planning-progress-range" data-field="Avancement" value="0" /><span class="planning-progress-value">0%</span></div></td>
                <td class="planning-task-checkbox-cell"><input type="checkbox" class="form-check-input" data-field="EstJalon" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Dependances" placeholder="1;2" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Commentaire" /></td>
                <td class="planning-task-actions-cell"><button type="button" class="btn-modern btn-modern-secondary icon-button" data-planning-remove="true" title="Supprimer la tâche"><i class="bi bi-trash"></i></button></td>
            `;
            tbody.appendChild(row);
        },
        addRaciRow: function () {
            const tbody = document.querySelector('#raciTable tbody');
            if (!tbody) return;

            const row = document.createElement('tr');
            row.innerHTML = `
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="CodeActivite" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Activite" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Responsable" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Approbateur" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Consulte" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Informe" /></td>
                <td><button type="button" class="btn-modern btn-modern-secondary icon-button" data-raci-remove="true" title="Supprimer la ligne"><i class="bi bi-trash"></i></button></td>
            `;
            tbody.appendChild(row);
        },
        addCommunicationRow: function () {
            const tbody = document.querySelector('#communicationTable tbody');
            if (!tbody) return;

            const row = document.createElement('tr');
            row.innerHTML = `
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Instance" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Objectif" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Frequence" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Canal" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Participants" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Responsable" /></td>
                <td class="planning-task-checkbox-cell"><input type="checkbox" class="form-check-input" data-field="EstCopil" /></td>
                <td><button type="button" class="btn-modern btn-modern-secondary icon-button" data-communication-remove="true" title="Supprimer l'instance"><i class="bi bi-trash"></i></button></td>
            `;
            tbody.appendChild(row);
        },
        addBudgetRow: function () {
            const tbody = document.querySelector('#budgetTable tbody');
            if (!tbody) return;

            const row = document.createElement('tr');
            row.innerHTML = `
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Poste" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Description" /></td>
                <td><input type="number" step="0.01" class="form-control-modern form-control-modern-compact" data-field="Montant" value="0" /></td>
                <td><input type="text" class="form-control-modern form-control-modern-compact" data-field="Commentaire" /></td>
                <td><button type="button" class="btn-modern btn-modern-secondary icon-button" data-budget-remove="true" title="Supprimer le poste"><i class="bi bi-trash"></i></button></td>
            `;
            tbody.appendChild(row);
            window.planningBoard.refreshBudgetTotal();
        },
        removeRow: function (button) {
            const row = button.closest('tr');
            if (row) row.remove();
        },
        syncRange: function (input) {
            const wrapper = input.closest('.planning-progress-cell');
            const value = wrapper ? wrapper.querySelector('.planning-progress-value') : null;
            if (value) value.textContent = `${input.value}%`;
        },
        serializeTable: function (tableSelector, fields, checkboxFields, numberFields) {
            const rows = Array.from(document.querySelectorAll(`${tableSelector} tbody tr`));
            return rows.map((row, index) => {
                const payload = { Ordre: index };
                fields.forEach(field => {
                    const node = row.querySelector(`[data-field="${field}"]`);
                    if (!node) {
                        payload[field] = '';
                        return;
                    }

                    if ((numberFields || []).includes(field)) {
                        payload[field] = Number(node.value || 0);
                        return;
                    }

                    payload[field] = node.value || '';
                });
                (checkboxFields || []).forEach(field => {
                    const node = row.querySelector(`[data-field="${field}"]`);
                    payload[field] = !!(node && node.checked);
                });
                return payload;
            });
        },
        refreshBudgetTotal: function () {
            const rows = Array.from(document.querySelectorAll('#budgetTable tbody tr'));
            const total = rows.reduce((sum, row) => {
                const field = row.querySelector('[data-field="Montant"]');
                const value = field ? Number(field.value || 0) : 0;
                return sum + (Number.isFinite(value) ? value : 0);
            }, 0);

            const label = document.getElementById('budgetTotalValue');
            if (label) {
                label.textContent = `${total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} FCFA`;
            }

            const hidden = document.getElementById('BudgetPrevisionnelHidden');
            if (hidden) {
                hidden.value = total.toFixed(2);
            }
        },
        serializeKickOff: function () {
            return {
                DateReunion: document.getElementById('kickOffDate')?.value || null,
                Heure: document.getElementById('kickOffHeure')?.value || '',
                Lieu: document.getElementById('kickOffLieu')?.value || '',
                Animateur: document.getElementById('kickOffAnimateur')?.value || '',
                Objectifs: document.getElementById('kickOffObjectifs')?.value || '',
                Participants: document.getElementById('kickOffParticipants')?.value || '',
                OrdreDuJour: document.getElementById('kickOffOrdreDuJour')?.value || '',
                Decisions: document.getElementById('kickOffDecisions')?.value || '',
                Actions: document.getElementById('kickOffActions')?.value || '',
                Commentaires: document.getElementById('kickOffCommentaires')?.value || ''
            };
        },
        syncLegacySummaries: function (raci, communication) {
            const raciHidden = document.getElementById('RaciParActiviteHidden');
            if (raciHidden) {
                raciHidden.value = raci
                    .filter(line => line.Activite)
                    .map(line => `${line.CodeActivite ? `${line.CodeActivite} - ` : ''}${line.Activite} | R: ${line.Responsable} | A: ${line.Approbateur} | C: ${line.Consulte} | I: ${line.Informe}`)
                    .join('\n');
            }

            const freqHidden = document.getElementById('FrequenceReunionsHidden');
            if (freqHidden) {
                freqHidden.value = communication.filter(line => line.Instance || line.Frequence).map(line => `${line.Instance}: ${line.Frequence}`).join(' ; ');
            }

            const participantsHidden = document.getElementById('ParticipantsReunionsHidden');
            if (participantsHidden) {
                participantsHidden.value = communication.filter(line => line.Instance || line.Participants).map(line => `${line.Instance}: ${line.Participants}`).join('\n');
            }

            const canalHidden = document.getElementById('CanalCommunicationHidden');
            if (canalHidden) {
                canalHidden.value = communication.filter(line => line.Instance || line.Canal).map(line => `${line.Instance}: ${line.Canal}`).join(' ; ');
            }
        },
        serializeAll: function () {
            const ganttRows = window.planningBoard.serializeTable('#planningTasksTable',
                ['CodeWbs', 'Libelle', 'Responsable', 'DateDebutPrevue', 'DateFinPrevue', 'Avancement', 'Dependances', 'Commentaire'],
                ['EstJalon'],
                ['Avancement']);
            const raciRows = window.planningBoard.serializeTable('#raciTable',
                ['CodeActivite', 'Activite', 'Responsable', 'Approbateur', 'Consulte', 'Informe']);
            const communicationRows = window.planningBoard.serializeTable('#communicationTable',
                ['Instance', 'Objectif', 'Frequence', 'Canal', 'Participants', 'Responsable'],
                ['EstCopil']);
            const budgetRows = window.planningBoard.serializeTable('#budgetTable',
                ['Poste', 'Description', 'Montant', 'Commentaire'],
                [],
                ['Montant']);
            const kickOff = window.planningBoard.serializeKickOff();

            document.getElementById('ganttPayload').value = JSON.stringify(ganttRows);
            document.getElementById('raciPayload').value = JSON.stringify(raciRows);
            document.getElementById('communicationPayload').value = JSON.stringify(communicationRows);
            document.getElementById('budgetPayload').value = JSON.stringify(budgetRows);
            document.getElementById('kickOffPayload').value = JSON.stringify(kickOff);
            window.planningBoard.syncLegacySummaries(raciRows, communicationRows);
            window.planningBoard.refreshBudgetTotal();
            return true;
        }
    };

    document.addEventListener('DOMContentLoaded', function () {
        const addTaskButton = document.getElementById('planningAddTaskButton');
        if (addTaskButton) {
            addTaskButton.addEventListener('click', function () {
                window.planningBoard.addTaskRow();
            });
        }

        const addRaciButton = document.getElementById('raciAddRowButton');
        if (addRaciButton) {
            addRaciButton.addEventListener('click', function () {
                window.planningBoard.addRaciRow();
            });
        }

        const addCommunicationButton = document.getElementById('communicationAddRowButton');
        if (addCommunicationButton) {
            addCommunicationButton.addEventListener('click', function () {
                window.planningBoard.addCommunicationRow();
            });
        }

        const addBudgetButton = document.getElementById('budgetAddRowButton');
        if (addBudgetButton) {
            addBudgetButton.addEventListener('click', function () {
                window.planningBoard.addBudgetRow();
            });
        }

        const planificationZone = document.querySelector('.planning-gantt-shell');
        if (planificationZone) {
            planificationZone.addEventListener('click', function (event) {
                const element = event.target instanceof Element ? event.target.closest('[data-planning-remove="true"], [data-raci-remove="true"], [data-communication-remove="true"], [data-budget-remove="true"]') : null;
                if (!element) return;

                window.planningBoard.removeRow(element);
                window.planningBoard.refreshBudgetTotal();
            });

            planificationZone.addEventListener('input', function (event) {
                const target = event.target;
                if (target instanceof HTMLInputElement && target.matches('.planning-progress-range')) {
                    window.planningBoard.syncRange(target);
                }

                if (target instanceof HTMLInputElement && target.matches('#budgetTable [data-field="Montant"]')) {
                    window.planningBoard.refreshBudgetTotal();
                }
            });
        }

        const planningForm = document.getElementById('planningForm');
        if (planningForm) {
            planningForm.addEventListener('submit', function () {
                window.planningBoard.serializeAll();
            });
        }

        document.querySelectorAll('[data-confirm-submit]').forEach(function (button) {
            button.addEventListener('click', function (event) {
                const message = button.getAttribute('data-confirm-submit');
                if (message && !window.confirm(message)) {
                    event.preventDefault();
                }
            });
        });

        window.planningBoard.refreshBudgetTotal();
    });
</script>
