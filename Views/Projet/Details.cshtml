@using GestionProjects.Domain.Enums
@model GestionProjects.Application.ViewModels.Projet.ProjetDetailsViewModel
@inject GestionProjects.Application.Common.Interfaces.IPermissionService PermissionService

@{
    var projet = Model.Projet;
    ViewData["Title"] = $"Projet {projet.CodeProjet}";
    var activeTab = Model.ActiveTab;
    var isReadOnly = Model.IsReadOnly;
    var isDemandeurProject = Model.IsDemandeurProject;
    var canAccessCharges = Model.CanAccessCharges;
    var ui = await ProjetUiPermissionBuilder.BuildAsync(PermissionService, User, projet, isReadOnly, isDemandeurProject);
    var canShowDmReadOnlyBanner = isReadOnly && ui.HasProjectValidationAccess && !ui.IsProjectSponsor;
}

<div class="fade-in app-page">
    @if (canShowDmReadOnlyBanner)
    {
        <div class="alert-modern alert-modern-info mb-4">
            <i class="bi bi-info-circle-fill"></i>
            <div>
                <strong>Mode lecture seule</strong> - Ce projet appartient à votre direction mais vous n'en êtes pas le sponsor. Vous pouvez consulter les informations mais ne pouvez pas effectuer d'actions.
            </div>
        </div>
    }
    else if (isReadOnly && isDemandeurProject)
    {
        <div class="alert-modern alert-modern-info mb-4">
            <i class="bi bi-info-circle-fill"></i>
            <div>
                <strong>Suivi demandeur</strong> - Vous consultez ce projet en lecture seule parce qu'il provient de votre demande. Vous pouvez suivre son état et participer à la validation de clôture quand elle vous est soumise.
            </div>
        </div>
    }
    
    <!-- En-tête du projet -->
    <div class="card-modern mb-4">
        <div class="card-header-modern project-hero">
            <div class="project-hero-main">
                <h2 class="card-title-modern project-hero-title mb-0">
                    <i class="bi bi-folder"></i>
                    @projet.CodeProjet - @projet.Titre
                    @if (canShowDmReadOnlyBanner)
                    {
                        <span class="badge-modern badge-modern-secondary">
                            <i class="bi bi-eye"></i> Lecture seule
                        </span>
                    }
                    else if (isReadOnly && isDemandeurProject)
                    {
                        <span class="badge-modern badge-modern-secondary">
                            <i class="bi bi-eye"></i> Suivi demandeur
                        </span>
                    }
                </h2>
                <div class="page-hero-meta mt-2">
                    <span class="badge-modern badge-modern-@GetPhaseClass(projet.PhaseActuelle)">@projet.PhaseWorkflowLabel</span>
                    <span class="badge-modern badge-modern-@GetStatutClass(projet.StatutProjet)">@projet.StatutWorkflowLabel</span>
                    <span class="badge-modern badge-modern-@GetRAGClass(projet.IndicateurRAG)" title="Indicateur RAG calculé automatiquement (Budget, Planning, Risques, Livrables). Indicateur objectif de référence.">
                        RAG: @GetRAGLabel(projet.IndicateurRAG)
                    </span>
                    <span class="badge-modern badge-modern-@GetEtatClass(projet.EtatProjet)" title="État de santé déclaré par le pilote du projet.">@projet.EtatProjet</span>
                    @if (projet.EtatDivergeDuRAG)
                    {
                        <span class="badge-modern badge-modern-warning" title="L'État déclaré (@projet.EtatProjet) diverge du RAG calculé (@projet.EtatRAGEquivalent). L'écart doit être justifié.">
                            <i class="bi bi-exclamation-triangle"></i> Écart RAG
                        </span>
                    }
                </div>
                @if (projet.DemandeProjet != null)
                {
                    <div class="page-hero-meta mt-2">
                        <span class="soft-note" style="font-weight: 700;">
                            Workflow demande initiale :
                        </span>
                        @if (projet.DemandeProjet.DateValidationDM.HasValue)
                        {
                            <span class="badge-modern badge-modern-success" title="Validation initiale Directeur Métier enregistrée sur la demande source.">
                                <i class="bi bi-check-circle"></i>
                                Demande initiale validée DM le @projet.DemandeProjet.DateValidationDM.Value.ToString("dd/MM/yyyy")
                            </span>
                        }
                        else
                        {
                            <span class="badge-modern badge-modern-warning" title="La validation initiale Directeur Métier n'est pas encore enregistrée sur la demande source.">
                                <i class="bi bi-clock"></i>
                                Demande initiale en attente DM
                            </span>
                        }
                        @if (projet.DemandeProjet.DateValidationDSI.HasValue)
                        {
                            <span class="badge-modern badge-modern-success" title="Validation initiale DSI enregistrée sur la demande source.">
                                <i class="bi bi-check-circle"></i>
                                Demande initiale validée DSI le @projet.DemandeProjet.DateValidationDSI.Value.ToString("dd/MM/yyyy")
                            </span>
                        }
                        else
                        {
                            <span class="badge-modern badge-modern-warning" title="La validation initiale DSI n'est pas encore enregistrée sur la demande source.">
                                <i class="bi bi-clock"></i>
                                Demande initiale en attente DSI
                            </span>
                        }
                    </div>
                }
            </div>
            <div class="project-progress-panel">
                <div class="project-progress-copy">
                    <div class="project-progress-kicker">Avancement</div>
                    <div class="project-progress-value">@projet.PourcentageAvancementAffiche%</div>
                </div>
                <div class="project-progress-ring">
                    <svg width="100" height="100">
                        <circle cx="50" cy="50" r="40" fill="none" stroke="var(--gray-200)" stroke-width="8"/>
                        <circle cx="50" cy="50" r="40" fill="none" stroke="var(--primary-blue)" stroke-width="8"
                                stroke-dasharray="@(2 * Math.PI * 40)" 
                                stroke-dashoffset="@(2 * Math.PI * 40 * (1 - projet.PourcentageAvancementAffiche / 100.0))"
                                stroke-linecap="round"/>
                    </svg>
                    <div class="project-progress-ring-value">
                        @projet.PourcentageAvancementAffiche%
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation par onglets -->
    <div class="card-modern mb-4">
        <ul class="nav project-tabs">
            @* Vue d'ensemble *@
            <li class="nav-item">
                <a class="nav-link @(activeTab == "synthese" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "synthese" })">
                    <i class="bi bi-speedometer2"></i> Synthèse
                </a>
            </li>
            @* Phases du cycle de vie, dans l'ordre (avec marqueur d'avancement) *@
            <li class="nav-item">
                <a class="nav-link @(activeTab == "analyse" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "analyse" })">
                    <i class="bi bi-search"></i> Analyse @PhaseMarker(PhaseProjet.AnalyseClarification, projet.PhaseActuelle)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "planification" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "planification" })">
                    <i class="bi bi-calendar-check"></i> Planification @PhaseMarker(PhaseProjet.PlanificationValidation, projet.PhaseActuelle)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "execution" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "execution" })">
                    <i class="bi bi-play-circle"></i> Exécution @PhaseMarker(PhaseProjet.ExecutionSuivi, projet.PhaseActuelle)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "uat" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "uat" })">
                    <i class="bi bi-check2-square"></i> UAT & MEP @PhaseMarker(PhaseProjet.UatMep, projet.PhaseActuelle)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "cloture" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "cloture" })">
                    <i class="bi bi-flag"></i> Clôture @PhaseMarker(PhaseProjet.ClotureLeconsApprises, projet.PhaseActuelle)
                </a>
            </li>
            @* Outils transverses *@
            <li class="nav-item">
                <a class="nav-link @(activeTab == "collaboration" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "collaboration" })">
                    <i class="bi bi-people"></i> Collaboration
                </a>
            </li>
            @if (canAccessCharges && ui.CanOpenChargesTab)
            {
                <li class="nav-item">
                    <a class="nav-link @(activeTab == "charges" ? "active" : "")"
                       href="@Url.Action("Charges", new { id = projet.Id })">
                        <i class="bi bi-clock-history"></i> Charges
                    </a>
                </li>
            }
            @* Gouvernance : maîtrise du changement et de la valeur *@
            <li class="nav-item">
                <a class="nav-link @(activeTab == "avenants" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "avenants" })">
                    <i class="bi bi-file-earmark-diff"></i> Avenants
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeTab == "benefices" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "benefices" })">
                    <i class="bi bi-graph-up-arrow"></i> Bénéfices
                </a>
            </li>
            @* Traçabilité *@
            <li class="nav-item">
                <a class="nav-link @(activeTab == "historique" ? "active" : "")"
                   href="@Url.Action("Details", new { id = projet.Id, tab = "historique" })">
                    <i class="bi bi-clock-history"></i> Historique
                </a>
            </li>
        </ul>
    </div>

    <!-- Contenu des onglets -->
    @if (activeTab == "synthese")
    {
        @await Html.PartialAsync("_ProjetSynthese", Model)
    }
    else if (activeTab == "analyse")
    {
        @await Html.PartialAsync("_ProjetAnalyse", projet)
    }
    else if (activeTab == "planification")
    {
        @await Html.PartialAsync("_ProjetPlanification", Model)
    }
    else if (activeTab == "execution")
    {
        @await Html.PartialAsync("_ProjetExecution", Model)
    }
    else if (activeTab == "uat")
    {
        @await Html.PartialAsync("_ProjetUAT", Model)
    }
    else if (activeTab == "collaboration")
    {
        @await Html.PartialAsync("_ProjetCollaboration", Model)
    }
    else if (activeTab == "cloture")
    {
        @await Html.PartialAsync("_ProjetCloture", Model)
    }
    else if (activeTab == "avenants")
    {
        @await Html.PartialAsync("_ProjetAvenants", Model)
    }
    else if (activeTab == "benefices")
    {
        @await Html.PartialAsync("_ProjetBenefices", Model)
    }
    else if (activeTab == "historique")
    {
        @await Html.PartialAsync("_ProjetHistorique", Model)
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn-modern btn-modern-secondary">
            <i class="bi bi-arrow-left"></i>
            Retour à la liste
        </a>
    </div>
</div>

<!-- Modales -->
@if (ui.CanUseProjectModals)
{
    @await Html.PartialAsync("_UploadLivrableModal", Model)
    @await Html.PartialAsync("_AjouterAnomalieModal", Model)
    @await Html.PartialAsync("_AjouterRisqueModal", projet)
    @await Html.PartialAsync("_AjouterMembreModal", Model)
    @await Html.PartialAsync("_ModifierMembreModal", projet)
    @await Html.PartialAsync("_ModifierRisqueModal", projet)
}

@functions {
    // Marqueur d'avancement de phase sur les onglets : phase passée (✓), en cours (●), à venir (rien).
    Microsoft.AspNetCore.Html.IHtmlContent PhaseMarker(PhaseProjet tabPhase, PhaseProjet current)
    {
        if ((int)tabPhase < (int)current)
            return new Microsoft.AspNetCore.Html.HtmlString("<i class=\"bi bi-check-circle-fill\" style=\"color: var(--success); margin-left: .25rem;\" title=\"Phase terminée\"></i>");
        if ((int)tabPhase == (int)current)
            return new Microsoft.AspNetCore.Html.HtmlString("<i class=\"bi bi-record-circle-fill\" style=\"color: var(--primary-blue); margin-left: .25rem;\" title=\"Phase en cours\"></i>");
        return Microsoft.AspNetCore.Html.HtmlString.Empty;
    }

    string GetPhaseClass(GestionProjects.Domain.Enums.PhaseProjet phase)
    {
        return phase switch
        {
            GestionProjects.Domain.Enums.PhaseProjet.AnalyseClarification => "info",
            GestionProjects.Domain.Enums.PhaseProjet.PlanificationValidation => "warning",
            GestionProjects.Domain.Enums.PhaseProjet.ExecutionSuivi => "primary",
            GestionProjects.Domain.Enums.PhaseProjet.UatMep => "success",
            GestionProjects.Domain.Enums.PhaseProjet.ClotureLeconsApprises => "secondary",
            _ => "secondary"
        };
    }

    string GetStatutClass(GestionProjects.Domain.Enums.StatutProjet statut)
    {
        return statut switch
        {
            GestionProjects.Domain.Enums.StatutProjet.NonDemarre => "secondary",
            GestionProjects.Domain.Enums.StatutProjet.EnCours => "info",
            GestionProjects.Domain.Enums.StatutProjet.Suspendu => "warning",
            GestionProjects.Domain.Enums.StatutProjet.ClotureEnCours => "info",
            GestionProjects.Domain.Enums.StatutProjet.Cloture => "success",
            GestionProjects.Domain.Enums.StatutProjet.Annule => "danger",
            _ => "secondary"
        };
    }

    string GetEtatClass(GestionProjects.Domain.Enums.EtatProjet etat)
    {
        return etat switch
        {
            GestionProjects.Domain.Enums.EtatProjet.Vert => "success",
            GestionProjects.Domain.Enums.EtatProjet.Orange => "warning",
            GestionProjects.Domain.Enums.EtatProjet.Rouge => "danger",
            _ => "secondary"
        };
    }

    string GetRAGClass(GestionProjects.Domain.Enums.IndicateurRAG rag)
    {
        return rag switch
        {
            GestionProjects.Domain.Enums.IndicateurRAG.Vert => "success",
            GestionProjects.Domain.Enums.IndicateurRAG.Amber => "warning",
            GestionProjects.Domain.Enums.IndicateurRAG.Rouge => "danger",
            _ => "secondary"
        };
    }

    string GetRAGLabel(GestionProjects.Domain.Enums.IndicateurRAG rag)
    {
        return rag switch
        {
            GestionProjects.Domain.Enums.IndicateurRAG.Vert => "🟢 Vert",
            GestionProjects.Domain.Enums.IndicateurRAG.Amber => "🟡 Amber",
            GestionProjects.Domain.Enums.IndicateurRAG.Rouge => "🔴 Rouge",
            _ => "N/A"
        };
    }
}
