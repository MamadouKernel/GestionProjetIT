@functions {
    string GetValidationTone(StatutValidationCloture statut)
    {
        return statut switch
        {
            StatutValidationCloture.Validee => "is-success",
            StatutValidationCloture.Rejetee => "is-danger",
            _ => "is-warning"
        };
    }

    string GetValidationStatus(StatutValidationCloture statut)
    {
        return statut switch
        {
            StatutValidationCloture.Validee => "Validée",
            StatutValidationCloture.Rejetee => "Rejetée",
            _ => "En attente"
        };
    }
}
