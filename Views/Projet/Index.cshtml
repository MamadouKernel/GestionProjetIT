@model GestionProjects.Application.ViewModels.Projet.ProjetIndexViewModel
@inject GestionProjects.Application.Common.Interfaces.IPermissionService PermissionService

@{
    var isDemandeurOnlyView = Model.IsDemandeurOnlyView;
    var isDirecteurMetierProjectsView = Model.IsDirecteurMetierProjectsView;
    ViewData["Title"] = (isDemandeurOnlyView || isDirecteurMetierProjectsView) ? "Mes Projets" : "Portefeuille de Projets";
    ViewBag.PageNumber = Model.PageNumber;
    ViewBag.TotalPages = Model.TotalPages;
    ViewBag.TotalCount = Model.TotalCount;
    ViewBag.PageSize   = Model.PageSize;
}

<div class="fade-in app-page">
    @{
        var canManagePortfolio = await PermissionService.CurrentUserHasPermissionAsync("Projet", "Portefeuille");
    }

    @if (isDemandeurOnlyView)
    {
        <div class="alert-modern alert-modern-info mb-4">
            <i class="bi bi-info-circle-fill"></i>
            <div>
                <strong>Mode lecture seule</strong> - Cette vue regroupe les projets issus de vos demandes. Vous pouvez suivre leur avancement, leurs livrables et leur clôture sans les modifier.
            </div>
        </div>
    }
    else if (isDirecteurMetierProjectsView)
    {
        <div class="alert-modern alert-modern-info mb-4">
            <i class="bi bi-info-circle-fill"></i>
            <div>
                <strong>Mes projets</strong> - Cette vue regroupe les projets pour lesquels vous êtes sponsor en tant que Directeur métier. Vous pouvez suivre l'avancement, les livrables, les risques et réaliser les validations attendues.
            </div>
        </div>
    }
    
    @if (canManagePortfolio)
    {
        <div class="card-modern mb-4">
            <div class="card-header-modern">
                <h3 class="card-title-modern chart-card-title">
                    <i class="bi bi-funnel"></i>
                    Filtres
                </h3>
            </div>
            <div class="card-body-modern">
                <form asp-action="Index" method="get" id="filterForm">
                    <div class="filter-grid">
                        <div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Direction</label>
                                <select name="directionId" class="form-control-modern" asp-items="Model.Directions">
                                    <option value="">-- Toutes --</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Chef de Projet</label>
                                <select name="chefProjetId" class="form-control-modern" asp-items="Model.ChefsProjet">
                                    <option value="">-- Tous --</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Phase</label>
                                <select name="phase" class="form-control-modern" asp-items="Model.Phases">
                                    <option value="">-- Toutes --</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Statut</label>
                                <select name="statut" class="form-control-modern" asp-items="Model.Statuts">
                                    <option value="">-- Tous --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="filter-grid">
                        <div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">État</label>
                                <select name="etat" class="form-control-modern" asp-items="Model.Etats">
                                    <option value="">-- Tous --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="filter-actions mt-3">
                            <button type="submit" class="btn-modern btn-modern-primary">
                                <i class="bi bi-search"></i>
                                Filtrer
                            </button>
                            <a asp-action="Index" class="btn-modern btn-modern-secondary">
                                <i class="bi bi-x-circle"></i>
                                Réinitialiser
                            </a>
                    </div>
                </form>
            </div>
        </div>
    }

    <section class="page-hero">
        <div class="page-hero-main">
            <span class="page-kicker">
                <i class="bi bi-briefcase"></i>
                Pilotage portefeuille
            </span>
            <h1 class="page-hero-title">
                @((isDemandeurOnlyView || isDirecteurMetierProjectsView) ? "Mes projets" : "Portefeuille de projets")
            </h1>
            <p class="page-hero-subtitle">
                Une vue claire du portefeuille, des phases actives et des responsables clés, avec un accès direct à chaque fiche projet.
            </p>
        </div>
    </section>
    
    <div class="card-modern">
        <div class="card-header-modern">
            <h2 class="card-title-modern">
                <i class="bi bi-grid"></i>
                @((isDemandeurOnlyView || isDirecteurMetierProjectsView) ? "Mes Projets" : "Portefeuille de Projets")
            </h2>
        </div>

        @if (Model.Projets.Any())
        {
            <div class="table-responsive">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Titre</th>
                            <th>Direction</th>
                            <th>Sponsor</th>
                            <th>Chef de Projet</th>
                            <th>Phase</th>
                            <th>Statut</th>
                            <th>État</th>
                            <th>Avancement</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var projet in Model.Projets)
                        {
                            var isReadOnly = Model.ReadOnlyProjets.Contains(projet.Id);
                            
                            <tr class="@(isReadOnly ? "readonly-row" : "")">
                                <td>
                                    <div class="table-inline-stack">
                                        <strong class="table-code">@projet.CodeProjet</strong>
                                        @if (isReadOnly)
                                        {
                                            <span class="badge-modern badge-modern-secondary" title="Lecture seule - Projet de votre direction">
                                                <i class="bi bi-eye"></i> Lecture seule
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td>@projet.Titre</td>
                                <td>@(projet.Direction?.Libelle ?? "N/A")</td>
                                <td>
                                    <div class="table-inline-stack">
                                        @projet.Sponsor?.Nom @projet.Sponsor?.Prenoms
                                        @if (isReadOnly && projet.SponsorId != Guid.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? Guid.Empty.ToString()))
                                        {
                                            <span class="badge-modern badge-modern-info">
                                                <i class="bi bi-person-badge"></i> Autre DM
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td>@(projet.ChefProjet?.Nom ?? "Non assigné") @(projet.ChefProjet?.Prenoms ?? "")</td>
                                <td>
                                    <span class="badge-modern badge-modern-info">@projet.PhaseWorkflowLabel</span>
                                </td>
                                <td>
                                    <span class="badge-modern badge-modern-@GetStatutClass(projet.StatutProjet)">@projet.StatutWorkflowLabel</span>
                                </td>
                                <td>
                                    <span class="badge-modern badge-modern-@GetEtatClass(projet.EtatProjet)">@projet.EtatProjet</span>
                                </td>
                                <td>
                                    <div class="table-progress">
                                        <div class="table-progress-track">
                                            <div class="table-progress-bar" style="width: @projet.PourcentageAvancement%;"></div>
                                        </div>
                                        <span class="table-progress-value">@projet.PourcentageAvancement%</span>
                                    </div>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@projet.Id" class="btn-modern btn-modern-primary btn-icon" title="Consulter le projet" aria-label="Consulter le projet">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state-modern">
                <i class="bi bi-folder-x"></i>
                <p style="font-size: 1.1rem;">
                    Aucun projet trouvé.
                </p>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatutClass(GestionProjects.Domain.Enums.StatutProjet statut)
    {
        return statut switch
        {
            GestionProjects.Domain.Enums.StatutProjet.NonDemarre => "secondary",
            GestionProjects.Domain.Enums.StatutProjet.EnCours => "info",
            GestionProjects.Domain.Enums.StatutProjet.Suspendu => "warning",
            GestionProjects.Domain.Enums.StatutProjet.ClotureEnCours => "info",
            GestionProjects.Domain.Enums.StatutProjet.Cloture => "success",
            GestionProjects.Domain.Enums.StatutProjet.Annule => "danger",
            _ => "secondary"
        };
    }

    string GetEtatClass(GestionProjects.Domain.Enums.EtatProjet etat)
    {
        return etat switch
        {
            GestionProjects.Domain.Enums.EtatProjet.Vert => "success",
            GestionProjects.Domain.Enums.EtatProjet.Orange => "warning",
            GestionProjects.Domain.Enums.EtatProjet.Rouge => "danger",
            _ => "secondary"
        };
    }
}

@* Pagination *@
@await Html.PartialAsync("_Pagination")
