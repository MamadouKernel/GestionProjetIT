@model GestionProjects.Application.ViewModels.MotDePasseOublieViewModel
@{
    ViewData["Title"] = "Mot de passe oublié";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mot de passe oubli&eacute; - Z&eacute;&iuml;nab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-premium-page" data-controller="Account" data-action="MotDePasseOublie" data-page-title="Mot de passe oublié">
    <section class="auth-premium-left">
        <div class="auth-premium-blob is-one"></div>
        <div class="auth-premium-blob is-two"></div>

        <div class="auth-premium-brand">
            <img src="~/images/logo_cit.jpeg" alt="C&ocirc;te d'Ivoire Terminal" />
        </div>

        <div class="auth-premium-copy">
            <h1>Z&eacute;&iuml;nab</h1>
            <p>Renseignez votre matricule et votre email pour recevoir un lien s&eacute;curis&eacute; de r&eacute;initialisation.</p>
        </div>
    </section>

    <section class="auth-premium-right">
        <div class="auth-premium-panel">
            <div class="auth-premium-header">
                <div class="auth-premium-brand-fallback">
                    <div class="auth-premium-brand-fallback-icon">ZE</div>
                    <div class="auth-premium-brand-fallback-copy">
                        <strong>Z&eacute;&iuml;nab</strong>
                        <span>CIT · Portefeuille IT</span>
                    </div>
                </div>
                <h2 class="auth-premium-title">Mot de passe oubli&eacute;</h2>
                <p class="auth-premium-subtitle">Saisissez votre matricule et l'email associ&eacute; &agrave; votre compte.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-premium-alert is-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            if (!string.IsNullOrWhiteSpace(err.ErrorMessage))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        }
                    </div>
                </div>
            }

            <form asp-action="MotDePasseOublie" method="post" autocomplete="off" class="auth-premium-form">
                @Html.AntiForgeryToken()

                <div class="auth-premium-field">
                    <label asp-for="Matricule" class="form-label-modern"></label>
                    <div class="auth-premium-input-wrap">
                        <i class="bi bi-person auth-premium-field-icon"></i>
                        <input asp-for="Matricule" class="form-control-modern" autocomplete="username" placeholder="Votre matricule CIT" />
                    </div>
                </div>

                <div class="auth-premium-field">
                    <label asp-for="Email" class="form-label-modern"></label>
                    <div class="auth-premium-input-wrap">
                        <i class="bi bi-envelope auth-premium-field-icon"></i>
                        <input asp-for="Email" type="email" class="form-control-modern" autocomplete="email" placeholder="Votre email professionnel" />
                    </div>
                </div>

                <button type="submit" class="auth-premium-submit">
                    <i class="bi bi-send-check"></i>
                    Envoyer le lien de réinitialisation
                </button>
            </form>

            <p class="auth-premium-register">
                <a asp-action="Login">Retour à la connexion</a>
            </p>
        </div>
    </section>
</body>
</html>
