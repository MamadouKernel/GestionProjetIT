@{
    ViewData["Title"] = "Acces refuse";
}

<div class="fade-in access-state-shell">
    <div class="access-state-card">
        <div class="access-state-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <p class="page-kicker justify-content-center mb-3">
            <i class="bi bi-exclamation-octagon"></i>
            Autorisation requise
        </p>
        <h1 class="access-state-title">Acces refuse</h1>
        <p class="access-state-copy">
            Cette action ou cette page n'est pas ouverte pour votre profil actuel.
            Revenez vers votre tableau de bord ou contactez l'Admin IT si cet acces devrait exister.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Home" asp-action="Index" class="btn-modern btn-modern-primary">
                <i class="bi bi-house-door"></i>
                Retour au tableau de bord
            </a>
            <a asp-controller="Aide" asp-action="Index" class="btn-modern btn-modern-secondary">
                <i class="bi bi-question-circle"></i>
                Consulter l'aide
            </a>
        </div>
    </div>
</div>
