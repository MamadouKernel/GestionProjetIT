<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zéïnab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" asp-append-version="true" />
    <style>
        .sidebar {
            scrollbar-width: thin;
            scrollbar-color: var(--gray-300) transparent;
        }
        .sidebar::-webkit-scrollbar {
            width: 6px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: transparent;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background-color: var(--gray-300);
            border-radius: 3px;
        }
        .sidebar::-webkit-scrollbar-thumb:hover {
            background-color: var(--gray-400);
        }
    </style>
</head>
<body data-controller="@(ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty)"
      data-action="@(ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty)"
      data-page-title="@(ViewData["Title"]?.ToString() ?? string.Empty)">
    @if (User?.Identity?.IsAuthenticated == true)
    {
        <div class="app-container">
            <!-- Sidebar Overlay (mobile) -->
            <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
            
            <!-- Sidebar -->
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <div class="sidebar-brand">
                        <span class="logo-icon">ZE</span>
                        <div class="brand-copy">
                            <span class="brand-name">Zéïnab</span>
                            <span class="brand-caption">DSI Côte d'Ivoire Terminal</span>
                        </div>
                    </div>
                    <button class="sidebar-toggle d-none d-md-flex" id="sidebarCollapseBtn" onclick="toggleSidebarDesktop()" title="Réduire le menu" aria-label="Réduire le menu">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>
                <nav class="sidebar-nav">
                    @await Component.InvokeAsync("SidebarMenu")
                </nav>
            </aside>
            
            <!-- Main Content -->
            <div class="main-content">
                <div class="topbar">
                    <div class="d-flex align-items-center gap-3">
                        <button class="d-md-none" id="sidebarToggleBtn" onclick="toggleSidebar()" aria-label="Menu">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="topbar-heading">
                            <h1 class="topbar-title">@ViewData["Title"]</h1>
                            <div class="topbar-subtitle">Zéïnab · Pilotage des projets, validations et portefeuille IT</div>
                        </div>
                    </div>
                    <div class="topbar-user">
                        <!-- Notifications -->
                        <div class="dropdown">
                            <button class="notif-btn d-flex align-items-center justify-content-center" data-bs-toggle="dropdown" aria-expanded="false"
                                aria-label="Notifications non lues">
                                <i class="bi bi-bell"></i>
                                <span id="notificationBadge" class="notif-badge" hidden></span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end notif-dropdown">
                                <li class="notif-header">
                                    <span class="notif-title">Notifications</span>
                                    <a asp-controller="Notification" asp-action="Index" class="notif-see-all">Voir tout</a>
                                </li>
                                <li>
                                    <div id="notificationsList" class="notif-list" aria-live="polite" aria-busy="true">
                                        <div class="notif-state notif-loading">
                                            <span class="notif-state-icon"><i class="bi bi-arrow-repeat"></i></span>
                                            <span>Chargement des notifications...</span>
                                        </div>
                                    </div>
                                </li>
                            </ul>
                        </div>

                        <!-- User menu -->
                        <div class="dropdown">
                            @{
                                var nom = User.FindFirst("Nom")?.Value ?? "";
                                var prenom = User.FindFirst("Prenoms")?.Value ?? "";
                                var initiales = (!string.IsNullOrEmpty(nom) ? nom[0].ToString() : "") + (!string.IsNullOrEmpty(prenom) ? prenom[0].ToString() : "");
                                var roleLabel = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                            }
                            <div class="user-info" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="user-avatar">@initiales</div>
                                <div class="d-none d-sm-block">
                                    <div class="user-name">@nom @prenom</div>
                                    <div class="user-role-label">@roleLabel</div>
                                </div>
                                <i class="bi bi-chevron-down user-chevron"></i>
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li class="user-menu-header">
                                    <div class="user-menu-name">@nom @prenom</div>
                                    <div class="user-menu-role">@roleLabel</div>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profil">
                                        <i class="bi bi-person-circle"></i> Mon Profil
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Aide" asp-action="Index">
                                        <i class="bi bi-question-circle"></i> Aide
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form id="logoutForm" asp-controller="Account" asp-action="LogoutPost" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input id="logoutReason" type="hidden" name="reason" value="" />
                                        <button type="submit" class="dropdown-item logout-btn">
                                            <i class="bi bi-box-arrow-right text-danger"></i> Déconnexion
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                
                <div class="content-wrapper">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert-modern alert-modern-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill"></i>
                            <div>
                                <strong>Succès :</strong> @TempData["Success"]
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null || TempData["ErrorHtml"] != null)
                    {
                        <div class="alert-modern alert-modern-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <div>
                                <strong>Erreur :</strong>
                                @if (TempData["ErrorHtml"] != null)
                                {
                                    @Html.Raw(TempData["ErrorHtml"])
                                }
                                else
                                {
                                    @TempData["Error"]
                                }
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Warning"] != null)
                    {
                        <div class="alert-modern alert-modern-warning alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            <div>
                                <strong>Attention :</strong> @TempData["Warning"]
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Info"] != null)
                    {
                        <div class="alert-modern alert-modern-info alert-dismissible fade show" role="alert">
                            <i class="bi bi-info-circle-fill"></i>
                            <div>
                                <strong>Information :</strong> @TempData["Info"]
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    
                    <form id="antiForgeryForm" class="d-none">@Html.AntiForgeryToken()</form>
                    <div class="flex-grow-1">
                        @RenderBody()
                    </div>
                    
                    <footer class="layout-footer">
                        <span class="footer-copyright">&copy; @DateTime.Now.Year Côte d'Ivoire Terminal · DSI</span>
                        <span class="footer-version">Zéïnab v2.0</span>
                    </footer>
                </div>
            </div>
        </div>
    }
    else
    {
        <form id="antiForgeryForm" class="d-none">@Html.AntiForgeryToken()</form>
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        window.ZeinabLayout = {
            isAuthenticated: @(User?.Identity?.IsAuthenticated == true ? "true" : "false"),
            keepAliveUrl: '@Url.Action("KeepAlive", "Account")',
            notificationCountUrl: '@Url.Action("GetUnreadCount", "Notification")',
            notificationsUrl: '@Url.Action("GetUnreadNotifications", "Notification")?count=5',
            notificationFallbackUrl: '@Url.Action("Index", "Notification")'
        };
    </script>
    <script src="~/js/layout-shell.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
