@model GestionProjects.Application.ViewModels.DemandesAcces.DemandesAccesIndexViewModel
@using GestionProjects.Application.Common.Constants
@using GestionProjects.Domain.Enums

@{
    ViewData["Title"] = "Demandes d'accès";
    var directions     = Model.Directions;
    var recherche      = Model.Recherche ?? string.Empty;
    var selectedStatut = Model.SelectedStatut;
    var focusId        = Model.FocusId;
    var totalCount     = Model.TotalCount;
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="display-6 mb-0">
                <i class="bi bi-person-plus" style="color: var(--primary-blue);"></i>
                Demandes d'accès
            </h2>
            <p class="text-muted mb-0">Validation Admin IT des premiers accès applicatifs et des demandes locales.</p>
        </div>
        <span class="badge-modern badge-modern-info">@totalCount demande(s)</span>
    </div>

    <div class="card-modern mb-4">
        <div class="card-body-modern">
            <form method="get" asp-action="Index">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label-modern">Recherche</label>
                        <input type="text" name="recherche" value="@recherche"
                               class="form-control-modern" placeholder="Nom, prénom, e-mail ou matricule..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-modern">Statut</label>
                        <select name="statut" class="form-control-modern">
                            <option value="">Tous les statuts</option>
                            @foreach (StatutDemandeAcces s in Enum.GetValues(typeof(StatutDemandeAcces)))
                            {
                                <option value="@((int)s)" selected="@(selectedStatut == s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn-modern btn-modern-primary flex-fill">
                            <i class="bi bi-search"></i> Filtrer
                        </button>
                        @if (!string.IsNullOrWhiteSpace(recherche) || selectedStatut.HasValue || focusId.HasValue)
                        {
                            <a asp-action="Index" class="btn-modern btn-modern-secondary">
                                <i class="bi bi-x-circle"></i> Effacer
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }
    @if (focusId.HasValue)
    {
        <div class="alert alert-info d-flex justify-content-between align-items-center gap-3">
            <span>Demande ouverte depuis une notification.</span>
            <a asp-action="Index" class="btn-modern btn-modern-sm btn-modern-secondary">Voir toutes les demandes</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="card-modern">
            <div class="card-body-modern text-center" style="padding: var(--spacing-2xl);">
                <i class="bi bi-inbox" style="font-size: 3rem; color: var(--gray-400);"></i>
                <p class="mt-3 mb-0" style="color: var(--gray-500);">Aucune demande d'accès trouvée.</p>
            </div>
        </div>
    }
    else
    {
        <div style="display: grid; gap: var(--spacing-lg);">
            @foreach (var demande in Model.Items)
            {
                var badgeClass = demande.Statut switch
                {
                    GestionProjects.Domain.Enums.StatutDemandeAcces.Approuvee => "badge-modern-success",
                    GestionProjects.Domain.Enums.StatutDemandeAcces.Rejetee => "badge-modern-danger",
                    _ => "badge-modern-warning"
                };
                var isLocalAccessRequest = string.Equals(demande.AzureDepartment, AccessRequestConstants.LocalAzureDepartment, StringComparison.OrdinalIgnoreCase);
                var accessTypeLabel = isLocalAccessRequest ? AccessRequestConstants.LocalAccountLabel : AccessRequestConstants.MicrosoftAccountLabel;
                var accessTypeClass = isLocalAccessRequest ? "badge-modern-secondary" : "badge-modern-info";
                var accessTypeHelp = isLocalAccessRequest
                    ? "Activation par lien de mot de passe après approbation."
                    : $"{AccessRequestConstants.MicrosoftAccountLabel} déjà authentifié, à référencer dans l'application.";
                var isFocused = focusId == demande.Id;

                <div class="card-modern @(isFocused ? "border border-primary shadow-sm" : string.Empty)">
                    <div class="card-body-modern">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h4 class="mb-1">@demande.Prenoms @demande.Nom</h4>
                                <div class="text-muted">@demande.Email</div>
                            </div>
                            <div class="d-flex flex-wrap gap-2 justify-content-end">
                                <span class="badge-modern @accessTypeClass">@accessTypeLabel</span>
                                <span class="badge-modern @badgeClass">@demande.Statut</span>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <strong>Matricule</strong>
                                <div>@demande.Matricule</div>
                            </div>
                            <div class="col-md-4">
                                <strong>Type d'accès</strong>
                                <div>
                                    <span class="badge-modern @accessTypeClass">@accessTypeLabel</span>
                                    <div class="text-muted small mt-1">@accessTypeHelp</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <strong>Direction détectée</strong>
                                <div>@(demande.DirectionDetectee?.Libelle ?? "Non determinee")</div>
                            </div>
                            @if (!isLocalAccessRequest)
                            {
                                <div class="col-md-4">
                                    <strong>Département Microsoft 365</strong>
                                    <div>@(string.IsNullOrWhiteSpace(demande.AzureDepartment) ? "Non remonté" : demande.AzureDepartment)</div>
                                </div>
                            }
                            <div class="col-12">
                                <strong>Justification</strong>
                                <div>@demande.Justification</div>
                            </div>
                            @if (demande.DateTraitement.HasValue)
                            {
                                <div class="col-md-4">
                                    <strong>Approuvee par</strong>
                                    <div>
                                        @if (demande.TraitePar != null)
                                        {
                                            <text>@demande.TraitePar.Prenoms @demande.TraitePar.Nom</text>
                                            <div class="text-muted small">@demande.TraitePar.Matricule</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Inconnue</span>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <strong>Date traitement</strong>
                                    <div>@demande.DateTraitement.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                                <div class="col-md-4">
                                    <strong>Commentaire</strong>
                                    <div>@(string.IsNullOrWhiteSpace(demande.CommentaireTraitement) ? "Aucun" : demande.CommentaireTraitement)</div>
                                </div>
                            }
                        </div>

                        @if (Model.Traces.TryGetValue(demande.Id, out var trace) && demande.UtilisateurCree != null)
                        {
                            <div class="mt-3 p-3" style="border:1px solid var(--gray-200); border-radius: var(--radius-md); background: var(--gray-50);">
                                <strong class="d-block mb-2"><i class="bi bi-shield-check"></i> Trace du compte</strong>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <strong>Compte cree</strong>
                                        <div>@demande.UtilisateurCree.Matricule</div>
                                        @if (!string.IsNullOrWhiteSpace(demande.UtilisateurCree.CreePar))
                                        {
                                            <div class="text-muted small">par @demande.UtilisateurCree.CreePar le @demande.UtilisateurCree.DateCreation.ToString("dd/MM/yyyy HH:mm")</div>
                                        }
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Activation utilisateur</strong>
                                        <div>
                                            @if (trace.DateActivation.HasValue)
                                            {
                                                <span class="badge-modern badge-modern-success"><i class="bi bi-check2"></i> Activé</span>
                                                <div class="text-muted small">le @trace.DateActivation.Value.ToString("dd/MM/yyyy HH:mm")@(string.IsNullOrWhiteSpace(trace.ActiveDepuisIp) ? "" : $" (IP {trace.ActiveDepuisIp})")</div>
                                            }
                                            else
                                            {
                                                <span class="badge-modern badge-modern-warning"><i class="bi bi-clock"></i> En attente</span>
                                                <div class="text-muted small">L'utilisateur n'a pas encore clique son lien.</div>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Etat du compte</strong>
                                        <div>
                                            @if (trace.CompteDesactive)
                                            {
                                                <span class="badge-modern badge-modern-danger"><i class="bi bi-x-circle"></i> Desactive</span>
                                                <div class="text-muted small">
                                                    @if (!string.IsNullOrWhiteSpace(trace.DesactiveParMatricule))
                                                    {
                                                        <text>par @trace.DesactiveParMatricule</text>
                                                    }
                                                    @if (trace.DateDesactivation.HasValue)
                                                    {
                                                        <text> le @trace.DateDesactivation.Value.ToString("dd/MM/yyyy HH:mm")</text>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge-modern badge-modern-success"><i class="bi bi-person-check"></i> Actif</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (demande.Statut == GestionProjects.Domain.Enums.StatutDemandeAcces.EnAttente)
                        {
                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <form asp-action="Approuver" method="post" class="card-modern" style="border: 1px solid var(--gray-200);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@demande.Id" />
                                        <div class="card-body-modern">
                                            <h5 class="mb-3"><i class="bi bi-check-circle"></i> Approuver</h5>
                                            <div class="mb-3">
                                                <label class="form-label">Direction a retenir</label>
                                                <select class="form-select" name="directionId">
                                                    <option value="">Utiliser la direction détectée</option>
                                                    @foreach (var direction in directions)
                                                    {
                                                        var selected = direction.Value == demande.DirectionDetecteeId?.ToString();
                                                        <option value="@direction.Value" selected="@selected">@direction.Text</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Rôle à attribuer</label>
                                                <select class="form-select" name="role">
                                                    <option value="@((int)RoleUtilisateur.Demandeur)">Demandeur</option>
                                                    <option value="@((int)RoleUtilisateur.DirecteurMetier)">Directeur Métier</option>
                                                    <option value="@((int)RoleUtilisateur.ChefDeProjet)">Chef de projet</option>
                                                    <option value="@((int)RoleUtilisateur.ResponsableSolutionsIT)">Responsable Solutions IT</option>
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Commentaire (optionnel)</label>
                                                <textarea class="form-control" name="commentaire" rows="3"></textarea>
                                            </div>
                                            <button type="submit" class="btn-modern btn-modern-primary w-100">
                                                <i class="bi bi-check2"></i> Approuver et activer l'acces
                                            </button>
                                        </div>
                                    </form>
                                </div>
                                <div class="col-lg-6">
                                    <form asp-action="Rejeter" method="post" class="card-modern" style="border: 1px solid var(--gray-200);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@demande.Id" />
                                        <div class="card-body-modern">
                                            <h5 class="mb-3"><i class="bi bi-x-circle"></i> Rejeter</h5>
                                            <div class="mb-3">
                                                <label class="form-label">Commentaire de rejet</label>
                                                <textarea class="form-control" name="commentaire" rows="5" required></textarea>
                                            </div>
                                            <button type="submit" class="btn-modern btn-modern-danger w-100">
                                                <i class="bi bi-x-lg"></i> Rejeter la demande
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @await Html.PartialAsync("_Pagination")
</div>
