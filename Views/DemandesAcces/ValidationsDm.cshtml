@model GestionProjects.Application.ViewModels.DemandesAcces.DemandesAccesIndexViewModel
@using GestionProjects.Domain.Enums
@{
    ViewData["Title"] = "Validations d'accès — Directeur Métier";
    var recherche  = Model.Recherche ?? string.Empty;
    var statut     = Model.SelectedStatut;
    var totalCount = Model.TotalCount;
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="display-6 mb-0">
                <i class="bi bi-shield-check" style="color: var(--primary-blue);"></i>
                Validations d'accès — Directeur Métier
            </h2>
            <p class="text-muted mb-0">Première validation des demandes d'accès rattachées à votre direction.</p>
        </div>
        <span class="badge-modern badge-modern-info">@totalCount demande(s)</span>
    </div>

    <div class="card-modern mb-4">
        <div class="card-body-modern">
            <form method="get" asp-action="ValidationsDm">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label-modern">Recherche</label>
                        <input type="text" name="recherche" value="@recherche" class="form-control-modern" placeholder="Nom, prénom, e-mail ou matricule..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-modern">Statut</label>
                        <select name="statut" class="form-control-modern">
                            <option value="">Tous les statuts</option>
                            @foreach (StatutDemandeAcces s in Enum.GetValues(typeof(StatutDemandeAcces)))
                            {
                                <option value="@((int)s)" selected="@(statut == s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn-modern btn-modern-primary flex-fill"><i class="bi bi-search"></i> Filtrer</button>
                        <a asp-action="ValidationsDm" class="btn-modern btn-modern-secondary"><i class="bi bi-x-circle"></i> Effacer</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] is string success) { <div class="alert alert-success">@success</div> }
    @if (TempData["Info"] is string info) { <div class="alert alert-info">@info</div> }
    @if (TempData["Error"] is string error) { <div class="alert alert-danger">@error</div> }

    @if (!Model.Items.Any())
    {
        <div class="card-modern">
            <div class="card-body-modern text-center" style="padding: var(--spacing-2xl);">
                <i class="bi bi-inbox" style="font-size: 3rem; color: var(--gray-400);"></i>
                <p class="mt-3 mb-0" style="color: var(--gray-500);">Aucune demande d'accès à valider.</p>
            </div>
        </div>
    }
    else
    {
        <div style="display: grid; gap: var(--spacing-lg);">
            @foreach (var demande in Model.Items)
            {
                var badgeClass = demande.Statut switch
                {
                    StatutDemandeAcces.Approuvee       => "badge-modern-success",
                    StatutDemandeAcces.ApprouveeParDm  => "badge-modern-info",
                    StatutDemandeAcces.Rejetee         => "badge-modern-danger",
                    StatutDemandeAcces.RejeteeParDm    => "badge-modern-danger",
                    _                                  => "badge-modern-warning"
                };

                var enAttenteDm = demande.Statut == StatutDemandeAcces.EnAttente;
                var dejaTraitee = demande.Statut != StatutDemandeAcces.EnAttente;

                <div class="card-modern">
                    <div class="card-body-modern">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h4 class="mb-1">@demande.Prenoms @demande.Nom</h4>
                                <div class="text-muted">@demande.Email · @demande.Matricule</div>
                            </div>
                            <span class="badge-modern @badgeClass">@demande.Statut</span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <strong>Direction</strong>
                                <div>@(demande.DirectionDetectee?.Libelle ?? "—")</div>
                            </div>
                            <div class="col-md-8">
                                <strong>Justification</strong>
                                <div>@demande.Justification</div>
                            </div>
                        </div>

                        @if (dejaTraitee && demande.ValideeParDm != null)
                        {
                            <div class="alert-modern alert-modern-info mb-3">
                                <i class="bi bi-info-circle-fill"></i>
                                <div>
                                    Déjà traitée par <strong>@demande.ValideeParDm.Prenoms @demande.ValideeParDm.Nom</strong>
                                    @(demande.DateValidationDm.HasValue ? $"le {demande.DateValidationDm.Value:dd/MM/yyyy HH:mm}" : "")
                                    @if (!string.IsNullOrWhiteSpace(demande.CommentaireDm))
                                    {
                                        <text> — Commentaire : @demande.CommentaireDm</text>
                                    }
                                </div>
                            </div>
                        }

                        @if (enAttenteDm)
                        {
                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <form asp-action="ValiderParDm" method="post" class="card-modern" style="border: 1px solid var(--gray-200);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@demande.Id" />
                                        <div class="card-body-modern">
                                            <h5 class="mb-3"><i class="bi bi-check-circle"></i> Valider</h5>
                                            <div class="mb-3">
                                                <label class="form-label">Rôle à confirmer</label>
                                                <select class="form-select" name="roleConfirme">
                                                    <option value="@((int)RoleUtilisateur.Demandeur)">Demandeur</option>
                                                    <option value="@((int)RoleUtilisateur.ChefDeProjet)">Chef de projet</option>
                                                    <option value="@((int)RoleUtilisateur.ResponsableSolutionsIT)">Responsable Solutions IT</option>
                                                </select>
                                                <small class="text-muted">Vous pouvez ajuster le rôle si celui demandé n'est pas approprié.</small>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Commentaire (optionnel)</label>
                                                <textarea class="form-control" name="commentaire" rows="2"></textarea>
                                            </div>
                                            <button type="submit" class="btn-modern btn-modern-primary w-100">
                                                <i class="bi bi-check2"></i> Valider la demande
                                            </button>
                                        </div>
                                    </form>
                                </div>
                                <div class="col-lg-6">
                                    <form asp-action="RejeterParDm" method="post" class="card-modern" style="border: 1px solid var(--gray-200);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@demande.Id" />
                                        <div class="card-body-modern">
                                            <h5 class="mb-3"><i class="bi bi-x-circle"></i> Refuser</h5>
                                            <div class="mb-3">
                                                <label class="form-label">Motif de refus *</label>
                                                <textarea class="form-control" name="commentaire" rows="4" required></textarea>
                                            </div>
                                            <button type="submit" class="btn-modern btn-modern-danger w-100">
                                                <i class="bi bi-x-lg"></i> Refuser la demande
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
