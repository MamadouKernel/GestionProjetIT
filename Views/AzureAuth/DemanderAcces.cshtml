@model GestionProjects.Application.ViewModels.AzureAuth.DemanderAccesViewModel
@{
    ViewData["Title"] = "Demande d'accès";
    var email = Model.Email;
    var nom = Model.Nom;
    var prenom = Model.Prenom;
    var matricule = Model.Matricule;
    var azureDepartment = Model.AzureDepartment;
    var directionDetecteeId = Model.DirectionDetecteeId;
    var directionDetecteeNom = Model.DirectionDetecteeNom;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zéïnab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
</head>
<body style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card-modern" style="box-shadow: var(--shadow-xl);">
                    <div class="card-body-modern" style="padding: var(--spacing-xl);">
                        <div class="text-center mb-4">
                            <div style="width: 80px; height: 80px; background: var(--primary-blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto var(--spacing-lg);">
                                <i class="bi bi-person-plus" style="font-size: 2.5rem; color: white;"></i>
                            </div>
                            <h2 style="color: var(--gray-800); font-weight: 600; margin-bottom: var(--spacing-sm);">Utilisateur non référencé</h2>
                            <p style="color: var(--gray-600); font-size: 0.95rem;">
                                Votre compte CIT a été authentifié avec succès, mais vous n'êtes pas encore enregistré dans l'application.
                            </p>
                        </div>

                        @if (TempData["Info"] is string infoMessage)
                        {
                            <div class="alert alert-warning mb-4">@infoMessage</div>
                        }

                        <div class="alert-modern alert-modern-info mb-4">
                            <i class="bi bi-info-circle-fill"></i>
                            <div>
                                <strong>Informations détectées :</strong><br />
                                <strong>Email :</strong> @email<br />
                                <strong>Nom :</strong> @nom @prenom<br />
                                <strong>Matricule :</strong> @matricule<br />
                                <strong>Département Azure AD :</strong> @(string.IsNullOrWhiteSpace(azureDepartment) ? "Non remonté" : azureDepartment)<br />
                                <strong>Direction métier détectée :</strong> @directionDetecteeNom
                            </div>
                        </div>

                        <form asp-action="DemanderAcces" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@email" />
                            <input type="hidden" name="nom" value="@nom" />
                            <input type="hidden" name="prenom" value="@prenom" />
                            <input type="hidden" name="matricule" value="@matricule" />
                            <input type="hidden" name="azureDepartment" value="@azureDepartment" />
                            <input type="hidden" name="directionDetecteeId" value="@directionDetecteeId" />

                            <div class="mb-4">
                                <label for="justification" class="form-label" style="font-weight: 600; color: var(--gray-700);">
                                    <i class="bi bi-chat-left-text"></i> Justification de la demande <span style="color: var(--danger-color);">*</span>
                                </label>
                                <textarea class="form-control" id="justification" name="justification" rows="4" required
                                          placeholder="Expliquez pourquoi vous avez besoin d'accéder à cette application..."
                                          style="resize: vertical;"></textarea>
                                <small class="text-muted">Cette information sera transmise aux administrateurs IT.</small>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn-modern btn-modern-primary" style="padding: var(--spacing-md);">
                                    <i class="bi bi-send"></i> Envoyer la demande d'accès
                                </button>
                                <a asp-controller="Account" asp-action="Login" class="btn-modern btn-modern-secondary" style="padding: var(--spacing-md);">
                                    <i class="bi bi-arrow-left"></i> Retour à la connexion
                                </a>
                            </div>
                        </form>

                        <div class="mt-4 p-3" style="background: var(--gray-50); border-radius: var(--radius-md); border-left: 4px solid var(--primary-blue);">
                            <p style="margin: 0; font-size: 0.875rem; color: var(--gray-700);">
                                <i class="bi bi-clock-history" style="color: var(--primary-blue);"></i>
                                <strong>Que se passe-t-il ensuite ?</strong><br />
                                1. Votre demande sera envoyée aux administrateurs IT<br />
                                2. Ils examineront votre demande, compléteront les droits et valideront votre accès<br />
                                3. Vous recevrez un email de confirmation ou de refus<br />
                                4. Vous pourrez alors vous connecter à l'application
                            </p>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <p style="color: white; font-size: 0.875rem;">
                        <i class="bi bi-shield-check"></i> Connexion sécurisée via Azure Active Directory
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>

