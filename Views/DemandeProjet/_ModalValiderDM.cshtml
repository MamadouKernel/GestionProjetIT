@model GestionProjects.Domain.Models.DemandeProjet

<div class="modal fade" id="validerDMModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content app-modal-content">
            <form asp-action="ValiderDM" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header app-modal-header">
                    <h5 class="modal-title app-modal-title">
                        <i class="bi bi-check-circle-fill"></i>
                        Valider la demande
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body app-modal-body">
                    <p class="text-muted mb-4">
                        Vous êtes sur le point de valider cette demande. Elle sera ensuite transmise à la DSI pour validation finale.
                        <br><small class="app-modal-note"><i class="bi bi-info-circle"></i> Vous pouvez modifier certains champs avant validation.</small>
                    </p>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Titre *</label>
                        <input type="text" name="titre" class="form-control-modern" value="@Model.Titre" required />
                    </div>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Description *</label>
                        <textarea name="description" class="form-control-modern" rows="4" required>@Model.Description</textarea>
                    </div>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Objectifs *</label>
                        <textarea name="objectifs" class="form-control-modern" rows="4" required>@Model.Objectifs</textarea>
                    </div>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Avantages attendus</label>
                        <textarea name="avantagesAttendus" class="form-control-modern" rows="3">@Model.AvantagesAttendus</textarea>
                    </div>
                    
                    <div class="form-group-modern">
                        <label class="form-label-modern">Commentaire (optionnel)</label>
                        <textarea name="commentaire" class="form-control-modern" rows="3" placeholder="Ajoutez un commentaire si nécessaire..."></textarea>
                    </div>
                </div>
                <div class="modal-footer app-modal-footer">
                    <button type="button" class="btn-modern btn-modern-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i>
                        Annuler
                    </button>
                    <button type="submit" class="btn-modern btn-modern-success">
                        <i class="bi bi-check-circle"></i>
                        Valider
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
