@model GestionProjects.Application.ViewModels.Admin.ImportUsersViewModel
@{
    ViewData["Title"] = "Importer des Utilisateurs";
    var resultats = Model.Resultats;
    var erreurs = Model.Erreurs;
}

<div class="fade-in admin-page">
    <div class="page-toolbar">
        <div class="page-hero card-modern mb-0 flex-grow-1">
            <div class="page-hero-main">
                <span class="page-kicker">Administration</span>
                <h1 class="page-hero-title">Import utilisateurs Excel</h1>
                <p class="page-hero-subtitle">
                    Chargez des comptes en masse à partir d’un modèle structuré, avec contrôle des rôles et gestion des doublons.
                </p>
            </div>
        </div>
        <div class="admin-hero-actions">
            <a asp-action="Users" class="btn-modern btn-modern-secondary">
                <i class="bi bi-arrow-left"></i>
                Retour à la liste
            </a>
        </div>
    </div>

    @await Html.PartialAsync("_ValidationSummary")

    <div class="row g-4">
        <div class="col-xl-7">
            <div class="card-modern">
                <div class="card-header-modern">
                    <h3 class="card-title-modern">
                        <i class="bi bi-info-circle"></i>
                        Instructions d’import
                    </h3>
                </div>
                <div class="card-body-modern">
                    <div class="row g-4">
                        <div class="col-lg-6">
                            <div class="admin-panel">
                                <h4 class="admin-panel-heading">
                                    <i class="bi bi-file-earmark-spreadsheet"></i>
                                    Format du fichier Excel
                                </h4>
                                <ol class="mb-0" style="line-height: 1.9;">
                                    <li><strong>Matricule</strong> - obligatoire</li>
                                    <li><strong>Nom</strong> - obligatoire</li>
                                    <li><strong>Prénoms</strong> - obligatoire</li>
                                    <li><strong>Email</strong> - obligatoire</li>
                                    <li><strong>Code Direction</strong> - optionnel</li>
                                    <li><strong>Libellé Direction</strong> - optionnel</li>
                                    <li><strong>Rôles</strong> - optionnel, séparés par virgule</li>
                                    <li><strong>Peut Créer Demande</strong> - optionnel, Oui/Non</li>
                                </ol>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="admin-panel">
                                <h4 class="admin-panel-heading">
                                    <i class="bi bi-check-circle"></i>
                                    Rôles disponibles
                                </h4>
                                <ul class="list-soft">
                                    <li class="list-soft-item"><code>Demandeur</code></li>
                                    <li class="list-soft-item"><code>ChefDeProjet</code></li>
                                    <li class="list-soft-item"><code>DirecteurMetier</code></li>
                                    <li class="list-soft-item"><code>DSI</code></li>
                                    <li class="list-soft-item"><code>AdminIT</code></li>
                                    <li class="list-soft-item"><code>ResponsableSolutionsIT</code></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="admin-inline-note warning mt-4">
                        <i class="bi bi-exclamation-triangle"></i>
                        <div>
                            Si plusieurs rôles sont spécifiés, séparez-les par une virgule. Exemple : <code>Demandeur,ChefDeProjet</code>.
                        </div>
                    </div>

                    <div class="mt-4">
                        <h4 class="admin-panel-heading">
                            <i class="bi bi-table"></i>
                            Exemple de fichier
                        </h4>
                        <div class="admin-example-table">
                            <div class="table-responsive">
                                <table class="table table-modern">
                                    <thead>
                                        <tr>
                                            <th>Matricule</th>
                                            <th>Nom</th>
                                            <th>Prénoms</th>
                                            <th>Email</th>
                                            <th>Code Direction</th>
                                            <th>Libellé Direction</th>
                                            <th>Rôles</th>
                                            <th>Peut Créer Demande</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>EMP001</td>
                                            <td>DUPONT</td>
                                            <td>Jean</td>
                                            <td>jean.dupont@cit.ci</td>
                                            <td>DSI</td>
                                            <td>Système d'Information</td>
                                            <td>Demandeur</td>
                                            <td>Oui</td>
                                        </tr>
                                        <tr>
                                            <td>EMP002</td>
                                            <td>MARTIN</td>
                                            <td>Marie</td>
                                            <td>marie.martin@cit.ci</td>
                                            <td>DSI</td>
                                            <td>Système d'Information</td>
                                            <td>ChefDeProjet,DSI</td>
                                            <td>Oui</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card-modern sticky-card">
                <div class="card-header-modern">
                    <h3 class="card-title-modern">
                        <i class="bi bi-upload"></i>
                        Importer le fichier
                    </h3>
                </div>
                <div class="card-body-modern">
                    <div class="admin-inline-note mb-3">
                        <i class="bi bi-download"></i>
                        <div>
                            Téléchargez le modèle Excel pour partir de la bonne structure de colonnes.
                        </div>
                    </div>

                    <a asp-action="DownloadModeleImportUsers" class="btn-modern btn-modern-primary w-100 mb-4">
                        <i class="bi bi-download"></i>
                        Télécharger le modèle
                    </a>

                    <form asp-action="ImportUsers" method="post" enctype="multipart/form-data" class="action-stack">
                        @Html.AntiForgeryToken()

                        <div class="form-group-modern">
                            <label class="form-label-modern">
                                <i class="bi bi-file-earmark-excel"></i>
                                Fichier Excel (.xlsx) *
                            </label>
                            <input type="file" name="fichierExcel" class="form-control-modern" accept=".xlsx,.xls" required />
                            <small class="text-muted">Formats acceptés : <code>.xlsx</code> ou <code>.xls</code>.</small>
                        </div>

                        <div class="form-group-modern">
                            <label class="form-label-modern">
                                <i class="bi bi-key"></i>
                                Mot de passe par défaut *
                            </label>
                            <input type="password" name="motDePasseParDefaut" class="form-control-modern" required minlength="12" />
                            <small class="text-muted">Minimum 12 caractères, avec au moins une majuscule et un chiffre.</small>
                        </div>

                        <div class="admin-permission-card">
                            <input type="checkbox" name="ignorerDoublons" value="true" class="form-check-input" checked id="ignorerDoublons" />
                            <label class="form-check-label m-0" for="ignorerDoublons">
                                <strong>Ignorer les doublons</strong>
                                <small class="d-block text-muted">Les utilisateurs déjà existants par matricule ou email seront ignorés sans bloquer l’import.</small>
                            </label>
                        </div>

                        <div class="table-actions">
                            <button type="submit" class="btn-modern btn-modern-primary">
                                <i class="bi bi-upload"></i>
                                Importer
                            </button>
                            <a asp-action="Users" class="btn-modern btn-modern-secondary">
                                <i class="bi bi-x-circle"></i>
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (resultats.Any() || erreurs.Any())
    {
        <div class="card-modern">
            <div class="card-header-modern">
                <h3 class="card-title-modern">
                    <i class="bi bi-list-check"></i>
                    Résultats de l'importation
                </h3>
            </div>
            <div class="card-body-modern p-0">
                @if (resultats.Any())
                {
                    <div class="table-responsive">
                        <table class="table-modern">
                            <thead>
                                <tr>
                                    <th>Ligne</th>
                                    <th>Matricule</th>
                                    <th>Nom</th>
                                    <th>Statut</th>
                                    <th>Message</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var resultat in resultats)
                                {
                                    <tr>
                                        <td class="table-code">@resultat.Ligne</td>
                                        <td>@resultat.Matricule</td>
                                        <td>@resultat.Nom</td>
                                        <td>
                                            @if (resultat.Statut == "Créé")
                                            {
                                                <span class="badge-modern badge-modern-success">@resultat.Statut</span>
                                            }
                                            else if (resultat.Statut == "Ignoré")
                                            {
                                                <span class="badge-modern badge-modern-warning">@resultat.Statut</span>
                                            }
                                            else
                                            {
                                                <span class="badge-modern badge-modern-danger">@resultat.Statut</span>
                                            }
                                        </td>
                                        <td>@resultat.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (erreurs.Any())
                {
                    <div class="card-body-modern">
                        <div class="admin-inline-note warning">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <div>
                                <strong>Erreurs détaillées</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var erreur in erreurs)
                                    {
                                        <li>@erreur</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
