@model GestionProjects.Application.ViewModels.Admin.ServicesListViewModel

@{
    ViewData["Title"] = "Gestion des Services";
    var directions         = Model.Directions;
    var recherche          = Model.Recherche ?? string.Empty;
    var statut             = Model.Statut ?? string.Empty;
    var selectedDirId      = Model.SelectedDirectionId;
    var pageSize           = Model.PageSize;
    var filtreActif        = !string.IsNullOrWhiteSpace(recherche) || selectedDirId.HasValue || !string.IsNullOrWhiteSpace(statut);
}

<div class="fade-in admin-page">
    <div class="page-toolbar">
        <div class="page-hero card-modern mb-0 flex-grow-1">
            <div class="page-hero-main">
                <span class="page-kicker">Administration</span>
                <h1 class="page-hero-title">Gestion des services</h1>
                <p class="page-hero-subtitle">
                    Structurez les services rattachés aux directions métier et gardez un référentiel propre pour les affectations.
                </p>
                <div class="page-hero-meta">
                    <span class="badge-modern badge-modern-info">@Model.TotalCount service(s)</span>
                </div>
            </div>
        </div>

        <div class="admin-hero-actions">
            <button type="button" class="btn-modern btn-modern-primary" data-bs-toggle="modal" data-bs-target="#createServiceModal">
                <i class="bi bi-plus-circle"></i>
                Nouveau service
            </button>
        </div>
    </div>

    @await Html.PartialAsync("_ValidationSummary")

    <div class="admin-tabset nav nav-pills mb-4">
        <a asp-action="Users" class="nav-link">Utilisateurs</a>
        <a asp-action="ListeRoles" class="nav-link">Rôles</a>
        <a asp-action="Directions" class="nav-link">Directions</a>
        <a asp-action="Services" class="nav-link active">Services</a>
        <a asp-action="Delegations" class="nav-link">Délégations</a>
        <a asp-action="Parametres" class="nav-link">Paramètres</a>
    </div>

    <div class="card-modern mb-4">
        <div class="card-body-modern">
            <form method="get" asp-action="Services">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label-modern" for="recherche">Recherche</label>
                        <input type="text" id="recherche" name="recherche" value="@recherche"
                               class="form-control-modern" placeholder="Libellé ou code du service..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-modern" for="directionId">Direction</label>
                        <select id="directionId" name="directionId" class="form-control-modern">
                            <option value="">Toutes les directions</option>
                            @foreach (var dir in directions)
                            {
                                <option value="@dir.Id" selected="@(selectedDirId == dir.Id)">@dir.Libelle</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label-modern" for="statut">Statut</label>
                        <select id="statut" name="statut" class="form-control-modern">
                            <option value="" selected="@(statut == "")">Tous les statuts</option>
                            <option value="active" selected="@(statut == "active")">Actifs uniquement</option>
                            <option value="inactive" selected="@(statut == "inactive")">Inactifs uniquement</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <label class="form-label-modern" for="pageSize">Lignes</label>
                        <select id="pageSize" name="pageSize" class="form-control-modern">
                            @foreach (var ps in new[] { 5, 10, 20, 50, 100 })
                            {
                                <option value="@ps" selected="@(pageSize == ps)">@ps</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn-modern btn-modern-primary flex-fill">
                            <i class="bi bi-search"></i> Filtrer
                        </button>
                        @if (filtreActif)
                        {
                            <a asp-action="Services" class="btn-modern btn-modern-secondary" title="Effacer les filtres">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card-modern">
        <div class="card-header-modern">
            <div class="page-toolbar w-100">
                <div>
                    <h3 class="card-title-modern mb-1">
                        <i class="bi bi-boxes"></i>
                        Référentiel des services
                    </h3>
                    <p class="soft-note mb-0">Chaque service peut être activé, édité et rattaché à une direction.</p>
                </div>
                <span class="badge-modern badge-modern-info">@Model.TotalCount résultat(s)</span>
            </div>
        </div>

        @if (Model.Services.Any())
        {
            <div class="card-body-modern p-0">
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Service</th>
                                <th>Direction</th>
                                <th>Statut</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var service in Model.Services)
                            {
                                <tr>
                                    <td class="table-code">@service.Code</td>
                                    <td>
                                        <div class="table-inline-stack column">
                                            <span class="table-person-title">@service.Libelle</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (service.Direction != null)
                                        {
                                            <span class="badge-modern badge-modern-secondary">@service.Direction.Libelle</span>
                                        }
                                        else
                                        {
                                            <span class="soft-note">Non définie</span>
                                        }
                                    </td>
                                    <td>
                                        @if (service.EstActive)
                                        {
                                            <span class="badge-modern badge-modern-success">Actif</span>
                                        }
                                        else
                                        {
                                            <span class="badge-modern badge-modern-secondary">Inactif</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="table-actions justify-content-center">
                                            <button type="button"
                                                    class="btn-modern btn-modern-gold btn-icon"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#createServiceModal"
                                                    data-id="@service.Id"
                                                    data-code="@service.Code"
                                                    data-libelle="@service.Libelle"
                                                    data-direction="@service.DirectionId"
                                                    data-active="@service.EstActive.ToString().ToLowerInvariant()"
                                                    title="Modifier le service"
                                                    aria-label="Modifier le service">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form asp-action="DeleteService" asp-route-id="@service.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ce service ?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-modern btn-modern-danger btn-icon" title="Supprimer le service" aria-label="Supprimer le service">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-body-modern pt-0">
                @await Html.PartialAsync("_Pagination")
            </div>
        }
        else
        {
            <div class="card-body-modern empty-state-soft">
                <i class="bi bi-inbox"></i>
                @if (filtreActif)
                {
                    <p>Aucun service ne correspond aux filtres sélectionnés.</p>
                    <a asp-action="Services" class="btn-modern btn-modern-secondary mt-2">
                        <i class="bi bi-x-circle"></i> Effacer les filtres
                    </a>
                }
                else
                {
                    <p>Aucun service enregistré.</p>
                }
            </div>
        }
    </div>
</div>

<div class="modal fade" id="createServiceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content admin-modal-content">
            <form id="serviceForm" method="post" action="@Url.Action("CreateService")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="serviceId" value="" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-boxes"></i>
                        <span id="serviceModalTitle">Nouveau service</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body admin-modal-body">
                    <div class="admin-form-section">
                        <h6 class="admin-form-section-title">
                            <i class="bi bi-card-text"></i>
                            Informations du service
                        </h6>
                        <div class="form-group-modern">
                            <label class="form-label-modern" for="serviceDirectionId">Direction *</label>
                            <select name="DirectionId" id="serviceDirectionId" class="form-control-modern" required>
                                <option value="">-- Sélectionner une direction --</option>
                                @foreach (var dir in directions)
                                {
                                    <option value="@dir.Id" data-code="@dir.Code">@dir.Libelle</option>
                                }
                            </select>
                            <span class="text-danger field-validation-valid" data-valmsg-for="DirectionId" data-valmsg-replace="true"></span>
                        </div>
                        <div class="form-group-modern">
                            <label class="form-label-modern" for="serviceLibelle">Libellé *</label>
                            <input type="text" name="Libelle" id="serviceLibelle" class="form-control-modern" required maxlength="200" value="" />
                            <small class="text-muted">Le code est généré automatiquement à partir de la direction et du libellé.</small>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Libelle" data-valmsg-replace="true"></span>
                        </div>
                        <div class="form-group-modern">
                            <label class="form-label-modern" for="serviceCode">Code *</label>
                            <input type="text" name="Code" id="serviceCode" class="form-control-modern" required maxlength="50" value="" readonly style="background-color: var(--gray-50); cursor: not-allowed;" />
                            <small class="text-muted">Généré automatiquement, modifiable si nécessaire.</small>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Code" data-valmsg-replace="true"></span>
                        </div>
                        <div class="admin-permission-card">
                            <input type="checkbox" name="EstActive" id="serviceEstActive" value="true" class="form-check-input" checked />
                            <input type="hidden" name="EstActive" value="false" />
                            <label class="form-check-label m-0" for="serviceEstActive">
                                <strong>Service actif</strong>
                                <small class="d-block text-muted">Un service actif est proposé dans les formulaires et référentiels.</small>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn-modern btn-modern-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i>
                        Annuler
                    </button>
                    <button type="submit" class="btn-modern btn-modern-primary">
                        <i class="bi bi-save"></i>
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function generateCodeService() {
        var serviceId = document.getElementById('serviceId').value;
        if (serviceId) return;
        var dirSelect = document.getElementById('serviceDirectionId');
        var libelleInput = document.getElementById('serviceLibelle');
        var codeInput = document.getElementById('serviceCode');
        if (!dirSelect || !libelleInput || !codeInput) return;

        var selectedOption = dirSelect.options[dirSelect.selectedIndex];
        var dirCode = selectedOption ? selectedOption.getAttribute('data-code') : '';
        var libelle = libelleInput.value || '';
        if (!dirCode || !libelle) return;

        var ignore = ['de','des','du','le','la','les','un','une','et','ou','a','au','aux','en','pour','par','avec','sans','sous','sur','dans','entre','vers'];
        var initiales = libelle.replace(/'/g,' ').replace(/-/g,' ').replace(/\s+/g,' ').trim()
            .split(' ').filter(function(m) { return m.length >= 2 && !ignore.includes(m.toLowerCase()); })
            .map(function(m) { return m[0].toUpperCase(); }).join('');
        if (initiales) codeInput.value = dirCode + '-' + initiales;
    }

    function resetServiceForm() {
        document.getElementById('serviceForm').reset();
        document.getElementById('serviceForm').action = '@Url.Action("CreateService")';
        document.getElementById('serviceId').value = '';
        document.getElementById('serviceModalTitle').textContent = 'Nouveau service';
        document.getElementById('serviceCode').value = '';
        document.getElementById('serviceCode').readOnly = true;
        document.getElementById('serviceCode').style.backgroundColor = 'var(--gray-50)';
        document.getElementById('serviceCode').style.cursor = 'not-allowed';
        document.getElementById('serviceEstActive').checked = true;
    }

    document.addEventListener('DOMContentLoaded', function () {
        var modal = document.getElementById('createServiceModal');

        modal.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            if (btn && btn.dataset.id) {
                document.getElementById('serviceForm').action = '@Url.Action("UpdateService")';
                document.getElementById('serviceId').value = btn.dataset.id;
                document.getElementById('serviceDirectionId').value = btn.dataset.direction || '';
                document.getElementById('serviceLibelle').value = btn.dataset.libelle || '';
                document.getElementById('serviceCode').value = btn.dataset.code || '';
                document.getElementById('serviceEstActive').checked = btn.dataset.active === 'true';
                document.getElementById('serviceModalTitle').textContent = 'Modifier le service';
                document.getElementById('serviceCode').removeAttribute('readonly');
                document.getElementById('serviceCode').style.backgroundColor = '';
                document.getElementById('serviceCode').style.cursor = '';
            } else {
                resetServiceForm();
            }
        });

        modal.addEventListener('hidden.bs.modal', function () {
            resetServiceForm();
        });

        document.getElementById('serviceDirectionId').addEventListener('change', generateCodeService);
        document.getElementById('serviceLibelle').addEventListener('input', generateCodeService);

        document.getElementById('serviceCode').addEventListener('focus', function () {
            this.removeAttribute('readonly');
            this.style.backgroundColor = '';
            this.style.cursor = '';
        });
    });
</script>
}
