@model GestionProjects.Application.ViewModels.Admin.DirectionsListViewModel
@using GestionProjects.Domain.Models

@{
    ViewData["Title"] = "Gestion des Directions";
    var recherche   = Model.Recherche ?? string.Empty;
    var statut      = Model.Statut ?? string.Empty;
    var pageSize    = Model.PageSize;
    var filtreActif = !string.IsNullOrWhiteSpace(recherche) || !string.IsNullOrWhiteSpace(statut);
}

<div class="fade-in admin-page">
    <div class="page-toolbar">
        <div class="page-hero card-modern mb-0 flex-grow-1">
            <div class="page-hero-main">
                <span class="page-kicker">Administration</span>
                <h1 class="page-hero-title">Gestion des directions</h1>
                <p class="page-hero-subtitle">
                    Gérez les directions métier, leurs responsables et leur statut d'activation.
                </p>
                <div class="page-hero-meta">
                    <span class="badge-modern badge-modern-info">@Model.TotalCount direction(s)</span>
                </div>
            </div>
        </div>

        <div class="admin-hero-actions">
            <button type="button" class="btn-modern btn-modern-primary" data-bs-toggle="modal" data-bs-target="#createDirectionModal">
                <i class="bi bi-plus-circle"></i>
                Nouvelle direction
            </button>
        </div>
    </div>

    @await Html.PartialAsync("_ValidationSummary")

    @{
        var directionsSansDm = Model.Directions
            .Where(d => d.EstActive && !Model.DirectionsAvecDm.Contains(d.Id))
            .ToList();
    }
    @if (directionsSansDm.Count > 0)
    {
        <div class="alert-modern alert-modern-warning mb-4">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>@directionsSansDm.Count direction(s) active(s) sans Directeur Métier :</strong>
                @string.Join(", ", directionsSansDm.Select(d => d.Libelle)).
                Les demandes d'accès rattachées à ces directions sont bloquées
                tant qu'aucun DM n'y est affecté (page <em>Utilisateurs</em> → assigner le rôle).
            </div>
        </div>
    }

    <div class="admin-tabset nav nav-pills mb-4">
        <a asp-action="Users" class="nav-link">Utilisateurs</a>
        <a asp-action="ListeRoles" class="nav-link">Rôles</a>
        <a asp-action="Directions" class="nav-link active">Directions</a>
        <a asp-action="Services" class="nav-link">Services</a>
        <a asp-action="Delegations" class="nav-link">Délégations</a>
        <a asp-action="Parametres" class="nav-link">Paramètres</a>
    </div>

    <div class="card-modern mb-4">
        <div class="card-body-modern">
            <form method="get" asp-action="Directions">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label-modern" for="recherche">Recherche</label>
                        <input type="text" id="recherche" name="recherche" value="@recherche"
                               class="form-control-modern" placeholder="Libellé ou code de la direction..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-modern" for="statut">Statut</label>
                        <select id="statut" name="statut" class="form-control-modern">
                            <option value="" selected="@(statut == "")">Tous les statuts</option>
                            <option value="active" selected="@(statut == "active")">Actives uniquement</option>
                            <option value="inactive" selected="@(statut == "inactive")">Inactives uniquement</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label-modern" for="pageSize">Lignes / page</label>
                        <select id="pageSize" name="pageSize" class="form-control-modern">
                            @foreach (var ps in new[] { 5, 10, 20, 50, 100 })
                            {
                                <option value="@ps" selected="@(pageSize == ps)">@ps par page</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn-modern btn-modern-primary flex-fill">
                            <i class="bi bi-search"></i> Filtrer
                        </button>
                        @if (filtreActif)
                        {
                            <a asp-action="Directions" class="btn-modern btn-modern-secondary" title="Effacer les filtres">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card-modern">
        <div class="card-header-modern">
            <div class="page-toolbar w-100">
                <h3 class="card-title-modern">
                    <i class="bi bi-building"></i>
                    Référentiel des directions
                </h3>
                <span class="badge-modern badge-modern-info">@Model.TotalCount résultat(s)</span>
            </div>
        </div>

        @if (Model.Directions.Any())
        {
            <div class="card-body-modern p-0">
                <div class="table-responsive">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Libellé</th>
                                <th>Responsable</th>
                                <th>Statut</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var direction in Model.Directions)
                            {
                                <tr>
                                    <td class="table-code">@direction.Code</td>
                                    <td>
                                        <div class="table-inline-stack column">
                                            <span class="table-person-title">@direction.Libelle</span>
                                            @if (direction.EstActive && !Model.DirectionsAvecDm.Contains(direction.Id))
                                            {
                                                <span class="badge-modern badge-modern-warning" title="Aucun Directeur Métier rattaché : les demandes d'accès vers cette direction sont bloquées.">
                                                    <i class="bi bi-exclamation-triangle"></i> Aucun DM
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @if (direction.DSI != null)
                                        {
                                            <div class="table-person">
                                                <span class="table-avatar primary">@GetInitiales(direction.DSI.Nom, direction.DSI.Prenoms)</span>
                                                <div class="table-person-main">
                                                    <div class="table-person-title">@direction.DSI.Nom @direction.DSI.Prenoms</div>
                                                    <div class="table-person-subtitle">@direction.DSI.Email</div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="soft-note">Non assigné</span>
                                        }
                                    </td>
                                    <td>
                                        @if (direction.EstActive)
                                        {
                                            <span class="badge-modern badge-modern-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge-modern badge-modern-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="table-actions justify-content-center">
                                            <button type="button"
                                                    class="btn-modern btn-modern-gold btn-icon"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#createDirectionModal"
                                                    data-id="@direction.Id"
                                                    data-code="@direction.Code"
                                                    data-libelle="@direction.Libelle"
                                                    data-dsi="@(direction.DSIId?.ToString() ?? string.Empty)"
                                                    data-active="@direction.EstActive.ToString().ToLowerInvariant()"
                                                    title="Modifier la direction"
                                                    aria-label="Modifier la direction">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form asp-action="DeleteDirection" asp-route-id="@direction.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer cette direction ?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-modern btn-modern-danger btn-icon" title="Supprimer la direction" aria-label="Supprimer la direction">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-body-modern pt-0">
                @await Html.PartialAsync("_Pagination")
            </div>
        }
        else
        {
            <div class="card-body-modern empty-state-soft">
                <i class="bi bi-inbox"></i>
                @if (filtreActif)
                {
                    <p>Aucune direction ne correspond aux filtres sélectionnés.</p>
                    <a asp-action="Directions" class="btn-modern btn-modern-secondary mt-2">
                        <i class="bi bi-x-circle"></i> Effacer les filtres
                    </a>
                }
                else
                {
                    <p>Aucune direction enregistrée.</p>
                }
            </div>
        }
    </div>
</div>

<div class="modal fade" id="createDirectionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content admin-modal-content">
            <form id="directionForm" method="post" action="@Url.Action("CreateDirection")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="directionId" value="" />
                <div class="modal-header admin-modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-building"></i>
                        <span id="modalTitle">Nouvelle direction</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body admin-modal-body">
                    <div class="admin-form-section">
                        <h6 class="admin-form-section-title">
                            <i class="bi bi-card-text"></i>
                            Informations de base
                        </h6>
                        <div class="form-group-modern">
                            <label class="form-label-modern">Libellé *</label>
                            <input type="text" name="Libelle" id="libelle" class="form-control-modern" required maxlength="200" value="" />
                            <small class="text-muted">Le code sera généré automatiquement à partir du libellé.</small>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Libelle" data-valmsg-replace="true"></span>
                        </div>
                        <div class="form-group-modern">
                            <label class="form-label-modern">Code *</label>
                            <input type="text" name="Code" id="code" class="form-control-modern" required maxlength="50" value="" readonly style="background-color: var(--gray-50); cursor: not-allowed;" />
                            <small class="text-muted">Généré automatiquement, puis modifiable si nécessaire.</small>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Code" data-valmsg-replace="true"></span>
                        </div>
                        <div class="form-group-modern">
                            <label class="form-label-modern">Responsable de la direction</label>
                            <select name="DSIId" id="dsiId" class="form-control-modern">
                                <option value="">-- Non assigné --</option>
                                @if (Model.DSIs.Any())
                                {
                                    @foreach (var utilisateur in Model.DSIs)
                                    {
                                        <option value="@utilisateur.Id">@utilisateur.Nom @utilisateur.Prenoms</option>
                                    }
                                }
                                else
                                {
                                    <option value="" disabled>Aucun utilisateur disponible</option>
                                }
                            </select>
                            <small class="text-muted">Sélectionnez le responsable de cette direction.</small>
                            <span class="text-danger field-validation-valid" data-valmsg-for="DSIId" data-valmsg-replace="true"></span>
                        </div>
                        <div class="admin-permission-card">
                            <input type="checkbox" name="EstActive" id="estActive" value="true" class="form-check-input" checked />
                            <input type="hidden" name="EstActive" value="false" />
                            <label class="form-check-label m-0" for="estActive">
                                <strong>Direction active</strong>
                                <small class="d-block text-muted">Une direction active est disponible dans les formulaires et les workflows.</small>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer admin-modal-footer">
                    <button type="button" class="btn-modern btn-modern-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i>
                        Annuler
                    </button>
                    <button type="submit" class="btn-modern btn-modern-primary">
                        <i class="bi bi-save"></i>
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function resetDirectionForm() {
        document.getElementById('directionForm').reset();
        document.getElementById('directionForm').action = '@Url.Action("CreateDirection")';
        document.getElementById('directionId').value = '';
        document.getElementById('modalTitle').textContent = 'Nouvelle direction';
        document.getElementById('libelle').value = '';
        document.getElementById('code').value = '';
        document.getElementById('dsiId').value = '';
        document.getElementById('estActive').checked = true;
        var codeInput = document.getElementById('code');
        if (codeInput) {
            codeInput.readOnly = true;
            codeInput.style.backgroundColor = 'var(--gray-50)';
            codeInput.style.cursor = 'not-allowed';
        }
    }

    function generateCodeFromLibelle(libelle) {
        if (!libelle || libelle.trim() === '') return '';
        var normalise = libelle.trim().toLowerCase().replace(/'/g, ' ').replace(/-/g, ' ').replace(/\s+/g, ' ');
        if (normalise.includes('direction') && normalise.includes('exploitation')) return 'DEX';
        var ignore = ['de','des','du','le','la','les','un','une','et','ou','a','au','aux','en','pour','par','avec','sans','sous','sur','dans','entre','vers'];
        return libelle.replace(/'/g,' ').replace(/-/g,' ').replace(/\s+/g,' ').trim()
            .split(' ').filter(function(m) { return m.length >= 2 && !ignore.includes(m.toLowerCase()); })
            .map(function(m) { return m[0].toUpperCase(); }).join('');
    }

    document.addEventListener('DOMContentLoaded', function () {
        var modal = document.getElementById('createDirectionModal');

        modal.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            if (btn && btn.dataset.id) {
                // Mode édition : pré-remplir depuis les data-* du bouton
                document.getElementById('directionForm').action = '@Url.Action("UpdateDirection")';
                document.getElementById('directionId').value = btn.dataset.id;
                document.getElementById('code').value = btn.dataset.code || '';
                document.getElementById('libelle').value = btn.dataset.libelle || '';
                document.getElementById('dsiId').value = btn.dataset.dsi || '';
                document.getElementById('estActive').checked = btn.dataset.active === 'true';
                document.getElementById('modalTitle').textContent = 'Modifier la direction';
                var codeInput = document.getElementById('code');
                if (codeInput) {
                    codeInput.removeAttribute('readonly');
                    codeInput.style.backgroundColor = '';
                    codeInput.style.cursor = '';
                }
            } else {
                // Mode création
                resetDirectionForm();
            }
        });

        modal.addEventListener('hidden.bs.modal', function () {
            resetDirectionForm();
        });

        document.getElementById('libelle').addEventListener('input', function () {
            if (!document.getElementById('directionId').value) {
                var code = generateCodeFromLibelle(this.value);
                if (code) document.getElementById('code').value = code;
            }
        });

        document.getElementById('code').addEventListener('focus', function () {
            this.removeAttribute('readonly');
            this.style.backgroundColor = '';
            this.style.cursor = '';
        });
    });
</script>
}

@functions {
    string GetInitiales(string? nom, string? prenoms)
    {
        var initialNom = string.IsNullOrWhiteSpace(nom) ? "?" : nom.Trim()[0].ToString().ToUpperInvariant();
        var initialPrenom = string.IsNullOrWhiteSpace(prenoms) ? string.Empty : prenoms.Trim()[0].ToString().ToUpperInvariant();
        return $"{initialNom}{initialPrenom}";
    }
}
